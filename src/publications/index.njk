---
layout: layouts/base.njk
title: Publications - John Blake
description: Full list of publications by John Blake in NLP, computational linguistics, and language learning technology.
quote: '"Publish or perish."'
---

<section class="page-header">
  <div class="container">
    <h1>Publications</h1>
    <p class="lead mb-0">{{ publications | length }} publication{% if publications | length != 1 %}s{% endif %}</p>
  </div>
</section>

<section class="container py-4">

  <!-- View toggle tabs -->
  <ul class="nav nav-tabs mb-4" id="pubViewTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="chrono-tab" data-bs-toggle="tab" data-bs-target="#chrono" type="button" role="tab">
        Chronological
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="bytype-tab" data-bs-toggle="tab" data-bs-target="#bytype" type="button" role="tab">
        By Type
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="bystatus-tab" data-bs-toggle="tab" data-bs-target="#bystatus" type="button" role="tab">
        By Status
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="search-tab" data-bs-toggle="tab" data-bs-target="#search-pane" type="button" role="tab">
        Search
      </button>
    </li>
  </ul>

  <div class="tab-content" id="pubViewTabContent">

    <!-- Chronological view (newest first) -->
    <div class="tab-pane fade show active" id="chrono" role="tabpanel">
      {% if publications | length %}
        {% for pub in publications %}
          {% include "partials/pub-item.njk" %}
        {% endfor %}
      {% else %}
        <p class="text-muted">No publications yet.</p>
      {% endif %}
    </div>

    <!-- Grouped by type view -->
    <div class="tab-pane fade" id="bytype" role="tabpanel">
      {% set typeOrder = ["journal", "conference", "book_chapter", "book", "misc"] %}
      {% for type in typeOrder %}
        {% set items = publications | pubsByType(type) %}
        {% if items | length %}
          <h2 class="mt-4 mb-3">{{ type | typeLabel }}</h2>
          {% for pub in items %}
            {% include "partials/pub-item.njk" %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    </div>

    <!-- Grouped by status view -->
    <div class="tab-pane fade" id="bystatus" role="tabpanel">
      {% set underReview = publications | pubsByStatus("under_review") %}
      {% set inPress = publications | pubsByStatus("in_press") %}
      {% set published = publications | pubsByStatus("published") %}

      {% if underReview | length %}
        <h2 class="mt-4 mb-3">Under Review</h2>
        {% for pub in underReview %}
          {% include "partials/pub-item.njk" %}
        {% endfor %}
      {% endif %}

      {% if inPress | length %}
        <h2 class="mt-4 mb-3">In Press</h2>
        {% for pub in inPress %}
          {% include "partials/pub-item.njk" %}
        {% endfor %}
      {% endif %}

      {% if published | length %}
        <h2 class="mt-4 mb-3">Published</h2>
        {% for pub in published %}
          {% include "partials/pub-item.njk" %}
        {% endfor %}
      {% endif %}
    </div>

    <!-- Search view -->
    <div class="tab-pane fade" id="search-pane" role="tabpanel">
      <div class="mt-3 mb-3">
        <input type="text" id="pub-search-input" class="form-control pub-search-input"
               placeholder="Search by title or author name…" autocomplete="off">
      </div>
      <p id="pub-search-status" class="text-muted small mb-3">Type at least 2 characters to search.</p>
      <div id="pub-search-results">
        {% for pub in publications %}
          <div class="pub-search-item d-none"
               data-title="{{ pub.title }}"
               data-authors="{% for a in pub.authors %}{{ a.family }} {{ a.given }}{% if not loop.last %} {% endif %}{% endfor %}">
            {% include "partials/pub-item.njk" %}
          </div>
        {% endfor %}
      </div>
    </div>

  </div>

</section>

<script>
function pubCopy(btn, id) {
  const el = document.getElementById(id);
  navigator.clipboard.writeText(el.innerText).then(() => {
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = orig, 2000);
  });
}

(function() {
  const input = document.getElementById('pub-search-input');
  const status = document.getElementById('pub-search-status');
  const items = document.querySelectorAll('.pub-search-item');

  input.addEventListener('input', function() {
    const q = this.value.trim().toLowerCase();
    if (q.length < 2) {
      items.forEach(el => el.classList.add('d-none'));
      status.textContent = 'Type at least 2 characters to search.';
      return;
    }
    let count = 0;
    items.forEach(el => {
      const match =
        el.dataset.title.toLowerCase().includes(q) ||
        el.dataset.authors.toLowerCase().includes(q);
      el.classList.toggle('d-none', !match);
      if (match) count++;
    });
    status.textContent = count + ' publication' + (count !== 1 ? 's' : '') + ' found.';
  });

  // Focus search input when tab is activated
  document.getElementById('search-tab').addEventListener('shown.bs.tab', function() {
    input.focus();
  });
})();
</script>
