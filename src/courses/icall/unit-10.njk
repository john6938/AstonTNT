{# ══ Review ═══════════════════════════════════════════════════ #}

{% call reviewSection() %}
<div class="accordion mb-3" id="unit10-review">

  {% call accordion("rev-10-a", "Summary: Four changes in reported speech") %}
  <table class="table table-sm table-dark table-bordered" style="font-size:0.875rem;">
    <thead><tr><th>Change type</th><th>Rule</th></tr></thead>
    <tbody>
      <tr><td>Tense backshift</td><td>Move one step back: present → past, past → past perfect</td></tr>
      <tr><td>Pronoun change</td><td>I/me/my → you/your; we/us/our → you/your</td></tr>
      <tr><td>Modal backshift</td><td>will → would, can → could, may → might, must → had to</td></tr>
      <tr><td>Time expressions</td><td>now → then, today → that day, tomorrow → the following day</td></tr>
    </tbody>
  </table>
  {% endcall %}

  {% call accordion("rev-10-b", "Are backshift rules always required?") %}
  <p>
    Tense backshift is <em>not</em> required when the reporting verb is in the present tense
    (<em>"He says that…"</em>), or when the reported statement is a general truth
    (<em>"She said that water boils at 100°C."</em>). In these cases, the original tense
    may be retained.
  </p>
  {% endcall %}

</div>
<p class="mt-3 small" style="color:#e0e0e0;">
  <i class="bi bi-check-circle" style="color:#ff8c00;"></i>
  You have completed all 10 units of the iCALL Suite. Well done!
</p>
{% endcall %}
