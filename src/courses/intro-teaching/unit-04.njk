{% call reviewSection() %}
<p>Test your understanding of instructional communication.</p>

{% call quizMC("u04-q1", "What makes an Instruction-Checking Question (ICQ) effective?", 0,
   "An effective ICQ targets a specific, verifiable aspect of the task. 'How many examples will you write?' checks understanding of a concrete detail, unlike the vague 'Do you understand?'") %}
  <label class="quiz-option"><input type="radio" name="u04-q1" value="0"> It has a specific, verifiable answer</label>
  <label class="quiz-option"><input type="radio" name="u04-q1" value="1"> It asks "Do you understand?"</label>
  <label class="quiz-option"><input type="radio" name="u04-q1" value="2"> It covers multiple instruction steps at once</label>
{% endcall %}

<div class="mt-4">
{% call quizMC("u04-q2", "Concept-Checking Questions (CCQs) should focus on:", 1,
   "CCQs should probe meaning and conceptual understanding, not just vocabulary definitions or surface features of language.") %}
  <label class="quiz-option"><input type="radio" name="u04-q2" value="0"> Vocabulary definitions only</label>
  <label class="quiz-option"><input type="radio" name="u04-q2" value="1"> Meaning and understanding rather than form</label>
  <label class="quiz-option"><input type="radio" name="u04-q2" value="2"> Complex explanations from students</label>
{% endcall %}
</div>

<div class="mt-4">
{% call quizMC("u04-q3", "The main purpose of elicitation techniques is to:", 1,
   "Elicitation draws out students' existing knowledge and engages them actively, rather than simply testing memorised facts.") %}
  <label class="quiz-option"><input type="radio" name="u04-q3" value="0"> Test what students have memorised</label>
  <label class="quiz-option"><input type="radio" name="u04-q3" value="1"> Draw out student knowledge and engagement</label>
  <label class="quiz-option"><input type="radio" name="u04-q3" value="2"> Fill time when lessons run short</label>
{% endcall %}
</div>

<div class="mt-4">
{% call quizMC("u04-q4", "Socratic questioning is most effective for:", 1,
   "By guiding students through a chain of questions, Socratic dialogue leads them to insights through their own reasoning rather than passive reception.") %}
  <label class="quiz-option"><input type="radio" name="u04-q4" value="0"> Getting quick factual answers</label>
  <label class="quiz-option"><input type="radio" name="u04-q4" value="1"> Guiding students to independent insights</label>
  <label class="quiz-option"><input type="radio" name="u04-q4" value="2"> Showing students their mistakes</label>
{% endcall %}
</div>

<div class="mt-4">
{% call quizMC("u04-q5", "Effective feedback should begin with:", 0,
   "Specific praise for what was done well builds confidence and goodwill, making the subsequent corrective comments easier to receive and act upon.") %}
  <label class="quiz-option"><input type="radio" name="u04-q5" value="0"> Specific praise for what was done well</label>
  <label class="quiz-option"><input type="radio" name="u04-q5" value="1"> A list of all errors</label>
  <label class="quiz-option"><input type="radio" name="u04-q5" value="2"> General encouragement</label>
{% endcall %}
</div>

<p class="mt-4 small" style="color:#aaa;">
  <i class="bi bi-arrow-right-circle"></i>
  Proceed to <a href="{{ (courseBaseUrl + '/unit-05') | url }}">Unit 5: Aims, Objectives and Outcomes</a> when ready.
</p>
{% endcall %}


{% block scripts %}
<script>
(function () {
  var RESP = {
    r2: {
      specific: '<strong>Specific ICQ:</strong> Correct. "How many minutes do you have?" checks a concrete, verifiable detail of the task. If the student doesn\'t know, they didn\'t understand the instructions.',
      vague: '<strong>Vague question:</strong> Ineffective. Students almost always say "yes" to "Do you understand?" even when they don\'t. A good ICQ must require a specific answer.',
      leading: '<strong>Leading question:</strong> Ineffective. "This is clear, right?" invites agreement rather than checking actual understanding.'
    },
    r3: {
      vocab: '<strong>Vocabulary question:</strong> Tests memory of a definition, not conceptual understanding. A student could recite the definition without grasping the concept.',
      concept: '<strong>Conceptual CCQ:</strong> Excellent. Forces students to apply the distinction in a concrete scenario. If they answer correctly, they have understood the concept, not just the label.',
      understand: '<strong>"Is this concept clear?"</strong> Ineffective — students rarely admit confusion to the whole class. Always use targeted questions that require a specific answer.'
    },
    r6: {
      praise: '<strong>Acknowledge it works first:</strong> Excellent. Starting with what was achieved builds confidence and makes the student receptive to the corrective feedback that follows.',
      efficiency: '<strong>Focus on efficiency only:</strong> Misses the opportunity to affirm the student\'s achievement. Without initial praise, corrective feedback can feel discouraging.',
      list: '<strong>List all problems:</strong> Overwhelming and counterproductive. Focus on one or two high-priority improvements, not an exhaustive critique.'
    }
  };
  window.u04showResp = function (id, key) {
    var el = document.getElementById(id);
    if (el && RESP[id] && RESP[id][key]) {
      el.innerHTML = '<p class="mb-0">' + RESP[id][key] + '</p>';
      el.style.display = 'block';
    }
  };
}());
</script>
{% endblock %}
