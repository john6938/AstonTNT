permalink: /slides-viewer/
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Slide Viewer</title>
  <link rel="icon" type="image/x-icon" href="{{ '/favicon.ico' | url }}">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      overflow: hidden;
      background: #0d0d0d;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* ── Outer container ── */
    #sv-container {
      display: flex;
      flex-direction: column;
      width: 100vw;
      height: 100vh;
      background: #0d0d0d;
    }

    /* ── Input / launch screen ── */
    #sv-input {
      display: flex;
      flex: 1;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .sv-input-box {
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 12px;
      padding: 2.5rem 2rem;
      max-width: 440px;
      width: 100%;
      text-align: center;
    }

    .sv-input-box h1 {
      color: #ff8c00;
      font-size: 1.5rem;
      margin-bottom: 0.4rem;
    }

    .sv-input-box p {
      color: #999;
      font-size: 0.88rem;
      margin-bottom: 1.5rem;
      line-height: 1.5;
    }

    .sv-input-row {
      display: flex;
      gap: 0.5rem;
    }

    .sv-input-row input {
      flex: 1;
      background: #2a2a2a;
      border: 1px solid #444;
      border-radius: 6px;
      padding: 0.6rem 0.9rem;
      color: #fff;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.15s;
    }

    .sv-input-row input:focus { border-color: #ff8c00; }

    .sv-input-row input::placeholder { color: #666; }

    .sv-input-row button {
      background: #ff8c00;
      color: #000;
      border: none;
      border-radius: 6px;
      padding: 0.6rem 1.2rem;
      font-weight: 700;
      cursor: pointer;
      font-size: 0.95rem;
      transition: background 0.15s;
    }

    .sv-input-row button:hover { background: #e67e00; }

    .sv-back-link {
      display: block;
      margin-top: 1.5rem;
      font-size: 0.8rem;
      color: #555;
      text-decoration: none;
      transition: color 0.15s;
    }

    .sv-back-link:hover { color: #ff8c00; }

    /* ── Viewer ── */
    #sv-viewer {
      display: none;
      flex-direction: column;
      width: 100%;
      height: 100%;
      position: relative;
    }

    /* Slide image area — padded at bottom to leave room for controls */
    #sv-slide-area {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 0.5rem 0.5rem 60px;
    }

    #sv-slide-img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      display: block;
    }

    #sv-error {
      display: none;
      color: #e74c3c;
      font-size: 0.95rem;
      text-align: center;
      max-width: 440px;
      line-height: 1.7;
      padding: 0 1rem;
    }

    #sv-error strong { display: block; margin-bottom: 0.4rem; font-size: 1.05rem; }

    /* ── Controls bar ── */
    #sv-controls {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
      padding: 0 1rem;
      transition: opacity 0.5s ease;
    }

    #sv-controls.sv-controls-hidden {
      opacity: 0;
      pointer-events: none;
    }

    #sv-controls button {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.18);
      color: #ddd;
      border-radius: 6px;
      padding: 0.3rem 0.7rem;
      cursor: pointer;
      font-size: 1rem;
      line-height: 1.4;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

    #sv-controls button:hover:not(:disabled) {
      background: rgba(255,140,0,0.25);
      border-color: #ff8c00;
      color: #fff;
    }

    #sv-controls button:disabled {
      opacity: 0.25;
      cursor: not-allowed;
    }

    #sv-counter {
      font-size: 0.85rem;
      color: #bbb;
      min-width: 120px;
      text-align: center;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.02em;
    }

    /* Separator dot */
    .sv-sep {
      width: 1px;
      height: 20px;
      background: rgba(255,255,255,0.15);
    }

    /* ── Fullscreen: container must fill screen ── */
    #sv-container:fullscreen,
    #sv-container:-webkit-full-screen,
    #sv-container:-moz-full-screen {
      width: 100vw;
      height: 100vh;
      background: #0d0d0d;
    }
  </style>
</head>
<body>

<div id="sv-container">

  <!-- ── Input / launch screen ── -->
  <div id="sv-input">
    <div class="sv-input-box">
      <h1><img src="{{ '/assets/tnt_logo_small.jpg' | url }}" alt="Logo" style="height:36px; vertical-align:middle; border-radius:4px;"> &nbsp;Slide Viewer</h1>
      <p>Enter the presentation folder name.<br>
         Slides should be named <code style="color:#ff8c00;">Slide1.png</code>, <code style="color:#ff8c00;">Slide2.png</code>, etc.</p>
      <div class="sv-input-row">
        <input id="sv-deck-input" type="text" placeholder="e.g. teamworking" autocomplete="off" spellcheck="false">
        <button id="sv-deck-btn">Open</button>
      </div>
      <a href="{{ '/' | url }}" class="sv-back-link">← Back to site</a>
    </div>
  </div>

  <!-- ── Slide viewer ── -->
  <div id="sv-viewer">
    <div id="sv-slide-area">
      <img id="sv-slide-img" alt="Slide">
      <div id="sv-error">
        <strong>No slides found.</strong>
        Check that the folder name and file naming pattern are correct
        (<code>Slide1.png</code>, <code>Slide2.png</code>, …).
      </div>
    </div>

    <!-- Controls bar -->
    <div id="sv-controls">
      <button id="sv-prev" title="Previous slide (← / Backspace / Page Up)">
        <i class="bi bi-chevron-left"></i>
      </button>
      <span id="sv-counter">Slide 1</span>
      <button id="sv-next" title="Next slide (→ / Space / Page Down)">
        <i class="bi bi-chevron-right"></i>
      </button>
      <div class="sv-sep"></div>
      <button id="sv-fullscreen" title="Toggle fullscreen">
        <i class="bi bi-fullscreen"></i>
      </button>
      <button id="sv-change-deck" title="Open a different presentation">
        <i class="bi bi-folder2-open"></i>
      </button>
    </div>
  </div>

</div>

<!-- Pass pathPrefix-aware base path to JS -->
<script>
  window.SLIDE_VIEWER_CONFIG = {
    SLIDE_BASE:      "{{ '/slides/' | url }}",
    SLIDE_PREFIX:    "Slide",
    SLIDE_EXTENSION: ".png",
    LOOP_SLIDES:     false
  };
</script>
<script src="{{ '/assets/js/slide-viewer.js' | url }}"></script>

</body>
</html>
