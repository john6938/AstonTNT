<script>
(function () {
  var phrases = document.querySelectorAll('.efrw-phrase');
  var tooltip  = document.getElementById('efrw-tooltip');
  var countEl  = document.getElementById('efrw-count');
  var successEl = document.getElementById('efrw-success');
  var found = 0;

  var badgeClass = {
    accuracy:    'badge-accuracy',
    brevity:     'badge-brevity',
    clarity:     'badge-clarity',
    objectivity: 'badge-objectivity',
    formality:   'badge-formality'
  };

  function showTooltip(phrase, event) {
    var filter = phrase.dataset.filter;
    document.getElementById('efrw-tt-badge').textContent = phrase.dataset.filterLabel;
    document.getElementById('efrw-tt-badge').className   = 'efrw-tt-badge ' + badgeClass[filter];
    document.getElementById('efrw-tt-type').textContent        = phrase.dataset.errorType;
    document.getElementById('efrw-tt-correction').textContent  = phrase.dataset.correction;
    document.getElementById('efrw-tt-explanation').textContent = phrase.dataset.explanation;

    tooltip.style.display = 'block';

    var rect   = phrase.getBoundingClientRect();
    var tw     = tooltip.offsetWidth;
    var left   = rect.left;
    var top    = rect.bottom + 8;

    if (left + tw > window.innerWidth - 12) { left = window.innerWidth - tw - 12; }
    if (left < 8) { left = 8; }
    if (top + tooltip.offsetHeight > window.innerHeight - 8) {
      top = rect.top - tooltip.offsetHeight - 8;
    }

    tooltip.style.left = left + 'px';
    tooltip.style.top  = top  + 'px';
  }

  phrases.forEach(function (phrase) {
    phrase.addEventListener('mouseenter', function (e) {
      if (this.dataset.found === 'false') {
        this.dataset.found = 'true';
        found++;
        countEl.textContent = found;
        if (found === 5) { successEl.style.display = 'block'; }
      }
      showTooltip(this, e);
    });

    phrase.addEventListener('mouseleave', function () {
      tooltip.style.display = 'none';
    });

    // Touch / click support for mobile
    phrase.addEventListener('click', function (e) {
      e.stopPropagation();
      if (this.dataset.found === 'false') {
        this.dataset.found = 'true';
        found++;
        countEl.textContent = found;
        if (found === 5) { successEl.style.display = 'block'; }
      }
      showTooltip(this, e);
    });
  });

  document.addEventListener('click', function () {
    tooltip.style.display = 'none';
  });
}());
</script>
