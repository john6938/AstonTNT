<style>
/* ── Intro to University Teaching landing page — prefix: it- ── */

.it-accent {
  display: inline-block;
  background: #ff8c00;
  height: 4px; width: 50px;
  border-radius: 2px;
  margin-bottom: 0.9rem;
}

/* ── Progress dots ─────────────────────────────────────────── */
.it-progress {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.6rem;
}
.it-dot {
  width: 11px; height: 11px;
  border-radius: 50%;
  background: #444;
  border: 2px solid #555;
  transition: background 0.25s, border-color 0.25s, transform 0.2s;
}
.it-dot.it-done { background: #ff8c00; border-color: #ff8c00; }
.it-dot.it-cur  { background: transparent; border-color: #ff8c00; transform: scale(1.3); }
.it-prog-line {
  flex: 1; height: 2px;
  background: #333; border-radius: 1px;
  position: relative; overflow: hidden;
}
.it-prog-fill {
  position: absolute; left: 0; top: 0; bottom: 0;
  background: #ff8c00; border-radius: 1px;
  transition: width 0.4s ease;
}
.it-version-lbl { font-size: 0.78rem; color: #666; margin-bottom: 1.2rem; }
.it-version-lbl span { color: #ff8c00; font-weight: 700; }

/* ── Scenario panel ────────────────────────────────────────── */
.it-panel {
  background: #222;
  border-radius: 12px;
  padding: 1.8rem;
  border: 1px solid #333;
  animation: itSlideIn 0.35s ease;
  max-width: 680px;
  margin: 0 auto;
}
@keyframes itSlideIn {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
.it-scenario {
  font-style: italic;
  color: #e8e8e8;
  font-size: 1rem;
  margin-bottom: 1.2rem;
  padding: 0.7rem 1rem;
  background: rgba(255,140,0,0.07);
  border-left: 3px solid #ff8c00;
  border-radius: 0 6px 6px 0;
  line-height: 1.6;
}
.it-instruction { font-size: 0.82rem; color: #777; margin-bottom: 1.1rem; }

/* ── Option buttons ────────────────────────────────────────── */
.it-options { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.2rem; }
.it-option {
  background: #2a2a2a;
  border: 2px solid #444;
  border-radius: 8px;
  padding: 0.75rem 1rem;
  cursor: pointer;
  transition: border-color 0.14s, background 0.14s, transform 0.13s;
  color: #ddd;
  font-size: 0.9rem;
  line-height: 1.5;
  text-align: left;
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  width: 100%;
}
.it-option:hover { border-color: #ff8c00; background: #2e2e2e; transform: translateX(4px); }
.it-option.it-chosen { border-color: #ff8c00; background: rgba(255,140,0,0.1); cursor: default; transform: none; }
.it-option.it-dimmed { opacity: 0.38; cursor: default; transform: none; border-color: #383838; }
.it-opt-letter { font-weight: 700; color: #ff8c00; font-size: 0.85rem; min-width: 1rem; margin-top: 0.05rem; flex-shrink: 0; }

/* ── Feedback ──────────────────────────────────────────────── */
.it-feedback {
  display: none;
  margin-top: 0.8rem;
  padding: 0.75rem 1rem;
  background: rgba(255,140,0,0.05);
  border: 1px solid rgba(255,140,0,0.2);
  border-radius: 8px;
  font-size: 0.84rem;
  color: #ccc;
  line-height: 1.65;
}
.it-feedback strong { color: #ff8c00; }
.it-feedback em { color: #ddd; }

/* ── Actions ───────────────────────────────────────────────── */
.it-actions { display: flex; gap: 0.6rem; margin-top: 1.2rem; flex-wrap: wrap; align-items: center; }

/* ── Completion ────────────────────────────────────────────── */
.it-complete {
  display: none;
  background: #222;
  border-radius: 12px;
  padding: 2.5rem 2rem;
  border: 1px solid #333;
  text-align: center;
  animation: itSlideIn 0.4s ease;
  max-width: 680px;
  margin: 0 auto;
}
.it-complete h3 { color: #ff8c00; font-size: 1.5rem; margin-bottom: 0.3rem; }
.it-profile-name { font-size: 1.15rem; font-weight: 700; color: #fff; margin-bottom: 0.9rem; }
.it-tally-row { display: flex; justify-content: center; gap: 1rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
.it-tally-chip { padding: 0.3rem 0.9rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; border: 1px solid; }
.it-profile-desc { color: #ccc; font-size: 0.9rem; line-height: 1.75; margin-bottom: 1.25rem; max-width: 500px; margin-left: auto; margin-right: auto; }

/* ── About cards ───────────────────────────────────────────── */
.it-about-card {
  background: #1e1e1e;
  border: 1px solid #333;
  border-radius: 8px;
  padding: 1.2rem;
  height: 100%;
}
</style>

