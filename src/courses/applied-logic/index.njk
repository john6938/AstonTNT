<script>
(function () {

  // ── Task data (cards pre-shuffled so correct positions vary per task) ─────
  //   Correct positions: Task1=(1,2)  Task2=(0,3)  Task3=(1,3)  Task4=(0,2)
  var TASKS = [
    {
      id: 't1', type: 'abstract', label: 'Abstract',
      rule: 'If a card has a vowel on one side, then it has an even number on the other side.',
      cards: [
        { face: 'K',  sm: false, flip: false,
          hit:  'Correct — leave K. The rule only constrains vowels; a consonant can have any number on the back.',
          miss: 'K does not need to be flipped. The rule only applies to vowels — whatever is on the back is irrelevant.' },
        { face: 'E',  sm: false, flip: true,
          hit:  'Correct — flip E. A vowel is showing; the rule requires an even number on the back.',
          miss: 'You should flip E. It shows a vowel — you need to verify the back is even.' },
        { face: '7',  sm: false, flip: true,
          hit:  'Correct — flip 7. An odd number is showing; if there is a vowel on the back, the rule is violated.',
          miss: 'You should flip 7. If a vowel is hiding on the back, the rule is broken. This is the card most people overlook.' },
        { face: '4',  sm: false, flip: false,
          hit:  'Correct — leave 4. Even numbers can appear behind consonants without breaking the rule.',
          miss: '4 does not need to be flipped. The rule says vowels must pair with even numbers — not that even numbers must pair with vowels. Flipping 4 confirms but cannot falsify.' }
      ],
      insight: 'The correct answer is <strong>E and 7</strong> — positions 2 and 3. Most people choose <strong>E and 4</strong>. Selecting 4 feels right, but it can only confirm the rule, never break it. Selecting 7 is the logical move: an odd number paired with a vowel would be the fatal counterexample. The bias toward confirmation over falsification is one of the most robust findings in cognitive psychology.'
    },
    {
      id: 't2', type: 'abstract', label: 'Abstract',
      rule: 'If a card shows a circle on one side, then it shows red on the other side.',
      cards: [
        { face: '○',    sm: false, flip: true,
          hit:  'Correct — flip the circle. The rule requires red on the back; you need to check this holds.',
          miss: 'You should flip the circle. The rule requires red on the back of every circle.' },
        { face: 'RED',  sm: true,  flip: false,
          hit:  'Correct — leave the red card. Red can appear behind a square without breaking the rule.',
          miss: 'The red card does not need to be flipped. Red paired with a square is fine — the rule says circles must be red, not that red must be circles.' },
        { face: '□',    sm: false, flip: false,
          hit:  'Correct — leave the square. The rule says nothing about what colour squares must have on the back.',
          miss: 'The square does not need to be flipped. The rule only constrains circles.' },
        { face: 'BLUE', sm: true,  flip: true,
          hit:  'Correct — flip the blue card. If a circle is on the back, the rule is violated.',
          miss: 'You should flip blue. If a circle is hiding on the back, the rule is broken. This is the not-Q card that logic demands.' }
      ],
      insight: 'The correct answer is the <strong>circle and the blue card</strong> — the same logical structure as the vowel–number task. The circle is the P-card and blue is the not-Q card. Many people still choose red instead of blue, repeating the same confirmation error. Recognising that "not-Q" is the critical falsifier — not Q itself — is the core insight of conditional logic.'
    },
    {
      id: 't3', type: 'thematic', label: 'Thematic',
      rule: 'If a person is drinking beer, then they must be 18 years of age or over.',
      cards: [
        { face: 'Cola', sm: true,  flip: false,
          hit:  'Correct — no need to check the cola drinker. The rule only restricts beer consumption.',
          miss: 'The cola drinker does not need to be checked. Someone under 18 is perfectly allowed to drink cola.' },
        { face: 'Beer', sm: true,  flip: true,
          hit:  'Correct — check the beer drinker\'s age. If they are under 18, the rule is violated.',
          miss: 'You should check the beer drinker to confirm they are old enough.' },
        { face: '22',   sm: false, flip: false,
          hit:  'Correct — no need to check the 22-year-old. They are old enough to drink anything.',
          miss: 'No need to check the 22-year-old. Whatever they are drinking is within the rules.' },
        { face: '16',   sm: false, flip: true,
          hit:  'Correct — check what the 16-year-old is drinking. If it is beer, the rule is violated.',
          miss: 'You should check the 16-year-old. If they are drinking beer, the rule is broken.' }
      ],
      insight: 'Most people find this version <strong>easy</strong> — they immediately identify beer and 16 as the critical cards. Yet the logical structure is <em>identical</em> to the abstract tasks you just tried. The social context (a rule we recognise and enforce in everyday life) makes the correct answer feel obvious. This dramatic difference in performance is called the <strong>content effect</strong>.'
    },
    {
      id: 't4', type: 'thematic', label: 'Thematic',
      rule: 'If a letter is sealed, then it must carry a first-class stamp.',
      cards: [
        { face: '2nd',    sm: true, flip: true,
          hit:  'Correct — check the second-class stamp. If the envelope on the back is sealed, the rule is violated.',
          miss: 'You should check the second-class stamp. If it is on a sealed letter, the rule is broken.' },
        { face: 'Open',   sm: true, flip: false,
          hit:  'Correct — no need to check the open letter. The rule only applies to sealed envelopes.',
          miss: 'Open letters are not covered by the rule — whatever stamp they carry is irrelevant.' },
        { face: 'Sealed', sm: true, flip: true,
          hit:  'Correct — check the sealed letter. It must have a first-class stamp; if not, the rule is violated.',
          miss: 'You should check the sealed letter to confirm it has the correct stamp.' },
        { face: '1st',    sm: true, flip: false,
          hit:  'Correct — no need to check the first-class stamp. It is fine on either sealed or open letters.',
          miss: 'No need to check the first-class stamp. A first-class stamp on an open letter does not break the rule.' }
      ],
      insight: 'Based on Wason\'s own postal-rule study (1972), most people correctly choose <strong>2nd class</strong> and <strong>Sealed</strong>. Familiar institutional rules unlock the logic that abstract symbols obscure. The course asks: is this because familiarity reduces cognitive load, or because certain rule types — <em>social contracts</em>, obligations, permissions — activate a dedicated reasoning module in the brain?'
    }
  ];

  // ── State ─────────────────────────────────────────────────────────────────
  var cur      = 0;
  var selected = [];
  var checked  = false;
  var perfects = [false, false, false, false];

  // ── Render current task ───────────────────────────────────────────────────
  function render() {
    var t   = TASKS[cur];
    selected = [];
    checked  = false;

    // Update progress dots
    for (var i = 0; i < 4; i++) {
      var d = document.getElementById('al-d' + i);
      d.className = 'al-dot';
      if (i < cur)  d.classList.add(perfects[i] ? 'al-perfect' : 'al-done');
      if (i === cur) d.classList.add('al-cur');
    }
    // Progress fills (fill segment before current dot)
    ['al-fill','al-fill2','al-fill3'].forEach(function(id, idx) {
      document.getElementById(id).style.width = cur > idx ? '100%' : '0%';
    });

    document.getElementById('al-cur-num').textContent = cur + 1;
    document.getElementById('al-type-lbl').textContent = t.label + ' version';

    var bc = t.type === 'abstract' ? 'al-badge-abstract' : 'al-badge-thematic';
    var cardsHTML = t.cards.map(function(c, i) {
      var fc = c.sm ? 'al-card-face al-sm' : 'al-card-face';
      return '<div class="al-card" id="alc-' + i + '" onclick="alToggle(' + i + ')">'
        + '<div class="' + fc + '">' + c.face + '</div>'
        + '<div class="al-card-icon" id="alci-' + i + '"></div>'
        + '<div class="al-card-exp" id="alce-' + i + '"></div>'
        + '</div>';
    }).join('');

    var html = '<div class="al-task-panel">'
      + '<span class="al-badge ' + bc + '">' + t.label + '</span>'
      + '<div class="al-rule">&ldquo;' + t.rule + '&rdquo;</div>'
      + '<p class="al-instruction">Select every card that must be turned over to test this rule, then press Check.</p>'
      + '<div class="al-cards-row">' + cardsHTML + '</div>'
      + '<div class="al-score" id="al-score"></div>'
      + '<div class="al-insight" id="al-insight">' + t.insight + '</div>'
      + '<div class="al-actions">'
      + '<button class="tool-btn" id="al-check-btn" onclick="alCheck()" style="font-size:0.88rem; padding:0.4rem 1.2rem;">Check</button>'
      + '<button class="btn btn-outline-secondary btn-sm" id="al-retry-btn" onclick="alRetry()" style="display:none; font-size:0.82rem;">Try again</button>'
      + (cur < 3
          ? '<button class="btn btn-sm" id="al-next-btn" onclick="alNext()" style="display:none; background:#ff8c00; color:#000; font-weight:600; font-size:0.88rem; padding:0.4rem 1.2rem; margin-left:auto;">Next version <i class=\'bi bi-arrow-right ms-1\'></i></button>'
          : '<button class="btn btn-sm" id="al-next-btn" onclick="alFinish()" style="display:none; background:#ff8c00; color:#000; font-weight:600; font-size:0.88rem; padding:0.4rem 1.2rem; margin-left:auto;">See results <i class=\'bi bi-flag ms-1\'></i></button>')
      + '</div>'
      + '</div>';

    document.getElementById('al-task-area').innerHTML = html;
  }

  // ── Toggle card selection ─────────────────────────────────────────────────
  window.alToggle = function(idx) {
    if (checked) return;
    var pos = selected.indexOf(idx);
    if (pos === -1) selected.push(idx); else selected.splice(pos, 1);
    document.getElementById('alc-' + idx).classList.toggle('al-sel', selected.indexOf(idx) !== -1);
  };

  // ── Check ─────────────────────────────────────────────────────────────────
  window.alCheck = function() {
    checked = true;
    var t = TASKS[cur];
    var hits = 0, totalFlip = 0, wrongSel = 0;

    t.cards.forEach(function(c, i) {
      var wasSel = selected.indexOf(i) !== -1;
      var card = document.getElementById('alc-' + i);
      var icon = document.getElementById('alci-' + i);
      var exp  = document.getElementById('alce-' + i);
      card.classList.remove('al-sel');
      exp.style.display = 'block';
      if (c.flip) totalFlip++;

      if (c.flip && wasSel) {
        card.classList.add('al-hit');
        icon.innerHTML = '<span style="color:#2ecc71;font-size:1.2rem;">&#10003;</span>';
        exp.textContent = c.hit;
        hits++;
      } else if (!c.flip && wasSel) {
        card.classList.add('al-miss');
        icon.innerHTML = '<span style="color:#e74c3c;font-size:1.2rem;">&#10007;</span>';
        exp.textContent = c.miss;
        wrongSel++;
      } else if (c.flip && !wasSel) {
        card.classList.add('al-skip');
        icon.innerHTML = '<span style="color:#f39c12;font-size:1rem;">!</span>';
        exp.textContent = c.miss;
      } else {
        card.classList.add('al-fine');
        exp.textContent = c.hit;
      }
    });

    var perfect = (hits === totalFlip && wrongSel === 0);
    perfects[cur] = perfect;

    var scoreEl = document.getElementById('al-score');
    if (perfect) {
      scoreEl.className   = 'al-score al-perfect';
      scoreEl.textContent = '✓ Perfect — you found exactly the right cards.';
    } else if (hits > 0 && wrongSel === 0) {
      scoreEl.className   = 'al-score al-partial';
      scoreEl.textContent = 'Partially correct — you found ' + hits + ' of ' + totalFlip + ' cards, with no wrong choices.';
    } else {
      scoreEl.className   = 'al-score al-wrong';
      scoreEl.textContent = 'Not quite — see the explanation for each card below.';
    }
    scoreEl.style.display = 'block';
    document.getElementById('al-insight').style.display = 'block';
    document.getElementById('al-check-btn').style.display = 'none';
    document.getElementById('al-retry-btn').style.display = 'inline-block';
    document.getElementById('al-next-btn').style.display  = 'inline-block';
  };

  // ── Retry current task ────────────────────────────────────────────────────
  window.alRetry = function() { render(); };

  // ── Next task ─────────────────────────────────────────────────────────────
  window.alNext = function() {
    cur++;
    render();
    document.getElementById('al-task-area').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // ── Show completion screen ────────────────────────────────────────────────
  window.alFinish = function() {
    var count = perfects.filter(Boolean).length;
    var stars = ['','⭐','⭐⭐','⭐⭐⭐','⭐⭐⭐⭐'][count] || '';

    var msgs = [
      'The tasks are designed to be hard — particularly the abstract versions. Read the insights and try again to sharpen your reasoning.',
      'You got one perfect. The abstract versions catch almost everyone. Try again and focus on the not-Q card.',
      'Two perfects — solid reasoning. Can you spot the pattern across all four versions?',
      'Three perfects — excellent. One more and you have mastered the selection task.',
      'Four out of four — outstanding. You reasoned like a logician on every version.'
    ];

    document.getElementById('al-complete-title').textContent =
      count === 4 ? 'Flawless reasoning!' : count >= 2 ? 'Well done!' : 'Good effort!';
    document.getElementById('al-stars').textContent = stars;
    document.getElementById('al-final-msg').textContent = msgs[count];

    // Per-task chips
    var chips = TASKS.map(function(t, i) {
      var ok = perfects[i];
      return '<span class="al-result-chip" style="background:' + (ok ? 'rgba(39,174,96,0.12)' : 'rgba(80,80,80,0.2)') + '; color:' + (ok ? '#2ecc71' : '#888') + '; border-color:' + (ok ? '#27ae60' : '#444') + ';">'
        + (ok ? '✓ ' : '') + t.label + ' ' + (i + 1)
        + '</span>';
    }).join('');
    document.getElementById('al-result-row').innerHTML = chips;

    // Update final dot
    var last = document.getElementById('al-d3');
    last.className = 'al-dot ' + (perfects[3] ? 'al-perfect' : 'al-done');
    document.getElementById('al-fill3').style.width = '100%';

    document.getElementById('al-task-area').style.display = 'none';
    document.getElementById('al-complete').style.display  = 'block';
    document.getElementById('al-complete').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // ── Restart ───────────────────────────────────────────────────────────────
  window.alRestart = function() {
    cur = 0;
    perfects = [false, false, false, false];
    document.getElementById('al-complete').style.display  = 'none';
    document.getElementById('al-task-area').style.display = 'block';
    render();
  };

  // ── Boot ──────────────────────────────────────────────────────────────────
  render();

})();
</script>
