      </div>

      <span class="wb-sep"></span>

      <button class="wb-btn" onclick="wbClear()" style="color:#f88; border-color:rgba(255,100,100,0.35);">
        <i class="bi bi-eraser"></i> Clear
      </button>
      <button class="wb-btn" onclick="wbOpenFs()" style="margin-left:auto;">
        <i class="bi bi-fullscreen"></i> Full screen
      </button>
    </div>

    <div class="wb-interim" id="wb-interim">
      <i class="bi bi-soundwave"></i> <span id="wb-interim-text"></span>
    </div>

    <div class="wb-board" id="wb-board" contenteditable="true" spellcheck="false"
         data-ph="Start typing here, or click Listen to transcribe your speech…"></div>

    <div class="wb-toast" id="wb-toast"></div>
  </div>

  <p style="color:#888; font-size:0.8rem; margin-top:0.6rem;">
    <i class="bi bi-info-circle"></i>
    Voice input uses the Web Speech API — works best in Chrome or Edge.
    <span id="wb-no-speech" style="display:none; color:#f88;">
