---
tool: 8
toolTitle: Virtual Board
title: "Tool 8: Virtual Board — Teacher Utilities"
description: "A virtual classroom board with speech-to-text, customisable background, and voice-controlled font colours."
---

<style>
@import url('https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap');

/* ── Container ───────────────────────────────────────────────── */
.wb-container {
  display: flex;
  flex-direction: column;
  border-radius: 6px;
  overflow: hidden;
  border: 4px solid #2a5a2a;
  background: #1c3d1c;
  position: relative;
  transition: background 0.25s, border-color 0.25s;
}

/* ── Toolbar ─────────────────────────────────────────────────── */
.wb-toolbar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.3rem;
  padding: 0.45rem 0.7rem;
  background: rgba(0,0,0,0.38);
  border-bottom: 1px solid rgba(255,255,255,0.09);
  flex-shrink: 0;
  transition: background 0.25s;
}
.wb-btn {
  padding: 0.22rem 0.6rem;
  font-size: 0.8rem;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.07);
  color: #ccc;
  cursor: pointer;
  white-space: nowrap;
  line-height: 1.5;
}
.wb-btn:hover { background: rgba(255,255,255,0.15); }
.wb-lt .wb-btn { border-color: #bbb; background: #fff; color: #333; }
.wb-lt .wb-btn:hover { background: #eee; }

.wb-mic-btn {
  border-color: #ff8c00 !important;
  color: #ff8c00 !important;
  background: rgba(255,140,0,0.12) !important;
  font-weight: 600;
}
.wb-mic-btn.wb-on {
  background: #ff8c00 !important;
  color: #000 !important;
  animation: wbPulse 1.4s ease-in-out infinite;
}
@keyframes wbPulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(255,140,0,0.5); }
  50%      { box-shadow: 0 0 0 8px rgba(255,140,0,0); }
}

.wb-sep {
  align-self: stretch;
  width: 1px;
  background: rgba(255,255,255,0.13);
  margin: 0;
}
.wb-lt .wb-sep { background: #ccc; }

.wb-status { font-size: 0.75rem; color: #ff8c00; min-width: 5rem; }
.wb-lt .wb-status { color: #cc7700; }

.wb-lang {
  font-size: 0.78rem;
  padding: 0.18rem 0.3rem;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.07);
  color: #ccc;
  cursor: pointer;
  max-width: 88px;
}
.wb-lt .wb-lang { border-color: #bbb; background: #fff; color: #333; }

/* ── Theme group ─────────────────────────────────────────────── */
.wb-theme-group { display: flex; gap: 0.18rem; }
.wb-theme-opt {
  padding: 0.2rem 0.5rem;
  font-size: 0.78rem;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.06);
  color: #aaa;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.28rem;
  white-space: nowrap;
  line-height: 1.5;
}
.wb-theme-opt:hover { background: rgba(255,255,255,0.13); color: #ddd; }
.wb-theme-opt.wb-act { border-color: #ff8c00; color: #ff8c00; background: rgba(255,140,0,0.12); }
.wb-lt .wb-theme-opt { border-color: #bbb; background: #fff; color: #555; }
.wb-lt .wb-theme-opt:hover { background: #eee; color: #333; }
.wb-lt .wb-theme-opt.wb-act { border-color: #cc7700; color: #cc7700; background: rgba(204,119,0,0.08); }

.wb-tdot {
  width: 9px; height: 9px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
  border: 1px solid rgba(255,255,255,0.25);
}

/* ── Colour palette ──────────────────────────────────────────── */
.wb-palette { display: flex; align-items: center; gap: 0.22rem; }
.wb-swatch {
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.18);
  cursor: pointer;
  padding: 0;
  flex-shrink: 0;
  transition: transform 0.12s, border-color 0.12s;
}
.wb-swatch:hover { transform: scale(1.28); }
.wb-swatch.wb-act { border-color: #fff !important; box-shadow: 0 0 0 1px rgba(0,0,0,0.5); }
.wb-lt .wb-swatch.wb-act { border-color: #333 !important; }
.wb-cpick {
  width: 20px; height: 20px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.22);
  padding: 0;
  cursor: pointer;
  overflow: hidden;
  background: none;
  flex-shrink: 0;
}
.wb-lt .wb-cpick { border-color: #bbb; }

/* ── Colour preview dot next to palette ─────────────────────── */
.wb-color-preview {
  width: 12px; height: 12px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.3);
  flex-shrink: 0;
  pointer-events: none;
}

/* ── Interim speech bar ──────────────────────────────────────── */
.wb-interim {
  padding: 0.28rem 1rem;
  background: rgba(255,140,0,0.08);
  border-bottom: 1px solid rgba(255,140,0,0.2);
  font-family: 'Caveat', cursive;
  font-size: 1.15rem;
  color: rgba(255,185,70,0.8);
  font-style: italic;
  flex-shrink: 0;
  display: none;
  min-height: 1.8rem;
  line-height: 1.5;
}

/* ── Board (contenteditable) ─────────────────────────────────── */
.wb-board {
  flex: 1;
  width: 100%;
  min-height: 380px;
  padding: 1.2rem 1.5rem;
  background: transparent;
  border: none;
  outline: none;
  font-family: 'Caveat', cursive;
  line-height: 1.6;
  box-sizing: border-box;
  overflow-y: auto;
  white-space: pre-wrap;
  word-wrap: break-word;
  cursor: text;
}
/* Placeholder via CSS */
.wb-board:empty::before {
  content: attr(data-ph);
  color: rgba(200,200,200,0.25);
  font-style: italic;
  pointer-events: none;
}
.wb-lt .wb-board:empty::before { color: rgba(0,0,0,0.2); }

/* ── Toast ───────────────────────────────────────────────────── */
.wb-toast {
  position: absolute;
  bottom: 1rem;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.72);
  color: #fff;
  padding: 0.35rem 1.1rem;
  border-radius: 20px;
  font-size: 0.82rem;
  white-space: nowrap;
  pointer-events: none;
  z-index: 20;
  display: none;
  border: 1px solid rgba(255,255,255,0.15);
}

/* ── Full-screen overlay ─────────────────────────────────────── */
#wb-fs {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  flex-direction: column;
}
#wb-fs .wb-container {
  height: 100%;
  border-radius: 0;
  border: none !important;
}
#wb-fs .wb-board { font-size: 3.5rem; }
</style>

<div class="course-tool-section mb-4" style="position:relative;">

