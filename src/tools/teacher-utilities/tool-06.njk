---
tool: 6
toolTitle: Topic Wheel
title: "Tool 6: Topic Wheel — Teacher Utilities"
description: "Spin the wheel to randomly select a topic. Edit topics freely, add as many as you need, and remove selected topics after each spin."
---

<div class="course-tool-section mb-4">

  <div class="activity-header">
    <span class="activity-num"><i class="bi bi-arrow-repeat"></i></span>
    <h2 class="activity-title-text">Topic Wheel</h2>
  </div>

  <p style="color:#ccc; margin-bottom:1.5rem;">
    Edit the topics on the left, then spin the wheel. After it stops, choose to <strong>keep</strong> the topic in the wheel or <strong>remove</strong> it so it won&rsquo;t appear again this session.
  </p>

  <div class="row g-4 align-items-start">

    {# ── Topic list ── #}
    <div class="col-md-5">
      <label class="tool-label mb-2">Topics</label>
      <div id="tw-list"></div>
      <div class="d-flex gap-2 mt-2 flex-wrap">
        <button onclick="twAddTopic()" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-plus-circle"></i> Add topic
        </button>
        <button onclick="twReset()" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-arrow-counterclockwise"></i> Reset defaults
        </button>
      </div>
    </div>

    {# ── Wheel ── #}
    <div class="col-md-7">
      <div style="display:flex; flex-direction:column; align-items:center;">
        <div style="width:0; height:0;
                    border-left:14px solid transparent;
                    border-right:14px solid transparent;
                    border-top:26px solid #ff8c00;
                    margin-bottom:-3px; position:relative; z-index:2;"></div>
        <canvas id="tw-canvas" width="380" height="380"
                style="max-width:100%; display:block; border-radius:50%;
                       box-shadow:0 0 24px rgba(0,0,0,0.6);"></canvas>
      </div>

      <div class="d-flex justify-content-center gap-2 mt-3 flex-wrap">
        <button id="tw-spin-btn" class="tool-btn"
                style="font-size:1.05rem; padding:0.7rem 2rem;"
                onclick="twSpin()">
          <i class="bi bi-arrow-clockwise"></i>&nbsp; Spin
        </button>
        <button class="tool-btn" style="font-size:1.05rem; padding:0.7rem 1.5rem; background:#1a3a5c;"
                onclick="twOpenFs()">
          <i class="bi bi-fullscreen"></i>&nbsp; Fullscreen
        </button>
      </div>

      {# Inline result panel #}
      <div id="tw-result"
           style="display:none; margin-top:1.25rem; padding:1.25rem;
                  background:#1e1e1e; border-radius:0.5rem; text-align:center;
                  border:2px solid #ff8c00;">
        <p style="color:#aaa; margin-bottom:0.35rem; font-size:0.78rem;
                  text-transform:uppercase; letter-spacing:0.07em;">Selected topic</p>
        <p id="tw-result-text"
           style="font-size:1.75rem; font-weight:800; color:#ff8c00;
                  margin-bottom:1rem; line-height:1.2; word-break:break-word;"></p>
        <div class="d-flex gap-2 justify-content-center flex-wrap">
          <button class="tool-btn" onclick="twKeep()">
            <i class="bi bi-check-circle me-1"></i>Keep in wheel
          </button>
          <button class="tool-btn" style="background:#6b1a1a;" onclick="twRemove()">
            <i class="bi bi-x-circle me-1"></i>Remove from wheel
          </button>
        </div>
      </div>
    </div>
  </div>

</div>

{# ── Fullscreen overlay ── #}
<div id="tw-fs"
     style="display:none; position:fixed; inset:0; background:#111; z-index:9999;
            flex-direction:column; align-items:center; justify-content:center; padding:1rem;">

  <div style="display:flex; flex-direction:column; align-items:center; width:100%; max-width:700px; flex:1; justify-content:center; gap:0;">
    {# Pointer #}
    <div style="width:0; height:0;
                border-left:18px solid transparent;
                border-right:18px solid transparent;
                border-top:34px solid #ff8c00;
                margin-bottom:-4px; position:relative; z-index:2;"></div>
    <canvas id="tw-fs-canvas" width="560" height="560"
            style="max-width:min(90vw, 70vh); max-height:min(90vw, 70vh);
                   display:block; border-radius:50%;
                   box-shadow:0 0 48px rgba(0,0,0,0.9);"></canvas>
  </div>

  {# FS controls #}
  <div style="display:flex; flex-direction:column; align-items:center; gap:0.75rem;
              width:100%; max-width:520px; margin-top:1.25rem; padding:0 0.5rem;">
    <button id="tw-fs-spin-btn" class="tool-btn"
            style="font-size:1.2rem; padding:0.8rem 3rem;"
            onclick="twSpin()">
      <i class="bi bi-arrow-clockwise"></i>&nbsp; Spin
    </button>

    <div id="tw-fs-result"
         style="display:none; width:100%; padding:1.1rem;
                background:#1e1e1e; border-radius:0.5rem; text-align:center;
                border:2px solid #ff8c00;">
      <p style="color:#aaa; margin-bottom:0.3rem; font-size:0.78rem;
                text-transform:uppercase; letter-spacing:0.07em;">Selected topic</p>
      <p id="tw-fs-result-text"
         style="font-size:2rem; font-weight:800; color:#ff8c00;
                margin-bottom:0.9rem; line-height:1.2; word-break:break-word;"></p>
      <div class="d-flex gap-2 justify-content-center flex-wrap">
        <button class="tool-btn" onclick="twKeep()">
          <i class="bi bi-check-circle me-1"></i>Keep in wheel
        </button>
        <button class="tool-btn" style="background:#6b1a1a;" onclick="twRemove()">
          <i class="bi bi-x-circle me-1"></i>Remove from wheel
        </button>
      </div>
    </div>
  </div>

  {# Exit button #}
  <button onclick="twExitFs()"
          style="position:absolute; top:1.1rem; right:1.1rem; background:transparent;
                 border:1px solid #555; color:#aaa; padding:0.45rem 1rem;
                 cursor:pointer; border-radius:0.375rem; font-size:0.95rem;">
    <i class="bi bi-fullscreen-exit"></i> Exit
  </button>
</div>

<script>
(function () {
  var DEFAULTS = ['Topic 1', 'Topic 2', 'Topic 3', 'Topic 4', 'Topic 5', 'Topic 6'];
  var COLORS   = [
    '#e05c00', '#2979d8', '#7b1fa2', '#2e7d32',
    '#b71c1c', '#006064', '#e65100', '#1565c0',
    '#4a148c', '#558b2f', '#880e4f', '#37474f'
  ];

  var topics     = DEFAULTS.slice();
  var spinAngle  = 0;
  var isSpinning = false;
  var winnerIdx  = -1;
  var animId     = null;
  var fsOpen     = false;

  /* ── Word-wrap helper ────────────────────────────────────────── */
  function wrapWords(ctx, text, maxWidth) {
    var words = text.split(' ');
    var lines = [];
    var cur   = '';
    for (var i = 0; i < words.length; i++) {
      var test = cur ? cur + ' ' + words[i] : words[i];
      if (ctx.measureText(test).width <= maxWidth) {
        cur = test;
      } else {
        if (cur) lines.push(cur);
        cur = words[i]; /* single word may exceed maxWidth — still one line */
      }
    }
    if (cur) lines.push(cur);
    return lines;
  }

  /* Find the largest font size where every label fits within maxLines lines */
  function bestLayout(ctx, r, n) {
    var seg    = (2 * Math.PI) / n;
    var tr     = r * 0.63;
    var availW = 2 * tr * Math.sin(seg / 2) * 0.78;
    var availH = r * 0.50;

    for (var fs = 18; fs >= 7; fs--) {
      ctx.font = 'bold ' + fs + 'px sans-serif';
      var lh  = fs * 1.3;
      var ok  = true;
      for (var i = 0; i < topics.length; i++) {
        var label = (topics[i] || '').trim() || ('Topic ' + (i + 1));
        var lines = wrapWords(ctx, label, availW);
        if (lines.length > 3 || lines.length * lh > availH) { ok = false; break; }
      }
      if (ok) return { fs: fs, lh: lh, availW: availW };
    }
    ctx.font = 'bold 7px sans-serif';
    return { fs: 7, lh: 9.1, availW: availW };
  }

  /* ── Draw wheel on a given canvas ────────────────────────────── */
  function drawOn(id, hi) {
    var canvas = document.getElementById(id);
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var W = canvas.width, H = canvas.height;
    var cx = W / 2, cy = H / 2;
    var r  = Math.min(cx, cy) - 6;
    var n  = topics.length;

    ctx.clearRect(0, 0, W, H);

    if (n === 0) {
      ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2 * Math.PI);
      ctx.fillStyle = '#2a2a2a'; ctx.fill();
      ctx.fillStyle = '#666';
      ctx.font = '15px sans-serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('Add topics to get started', cx, cy);
      return;
    }

    var seg    = (2 * Math.PI) / n;
    var layout = bestLayout(ctx, r, n);

    for (var i = 0; i < n; i++) {
      var a0 = spinAngle + i * seg;
      var a1 = a0 + seg;
      var isWin = (i === hi);

      /* segment fill */
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, a0, a1);
      ctx.closePath();
      ctx.fillStyle   = isWin ? '#ffd54f' : COLORS[i % COLORS.length];
      ctx.fill();
      ctx.strokeStyle = '#111';
      ctx.lineWidth   = 2;
      ctx.stroke();

      /* label */
      var mid   = a0 + seg / 2;
      var tr    = r * 0.63;
      var tx    = cx + tr * Math.cos(mid);
      var ty    = cy + tr * Math.sin(mid);
      var label = (topics[i] || '').trim() || ('Topic ' + (i + 1));

      ctx.font = 'bold ' + layout.fs + 'px sans-serif';
      var lines   = wrapWords(ctx, label, layout.availW);
      var totalH  = lines.length * layout.lh;

      ctx.save();
      ctx.translate(tx, ty);
      /* flip text on the left half so it stays readable */
      var rot = (Math.cos(mid) < 0) ? mid + Math.PI : mid;
      ctx.rotate(rot);
      ctx.fillStyle    = isWin ? '#000' : '#fff';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'middle';
      for (var li = 0; li < lines.length; li++) {
        var y = -totalH / 2 + layout.lh / 2 + li * layout.lh;
        ctx.fillText(lines[li], 0, y);
      }
      ctx.restore();
    }

    /* centre pin */
    ctx.beginPath(); ctx.arc(cx, cy, 10, 0, 2 * Math.PI);
    ctx.fillStyle = '#111'; ctx.fill();
    ctx.strokeStyle = '#555'; ctx.lineWidth = 2; ctx.stroke();
  }

  function redraw(hi) {
    drawOn('tw-canvas', hi);
    if (fsOpen) drawOn('tw-fs-canvas', hi);
  }

  /* ── Topic list renderer ─────────────────────────────────────── */
  function renderList() {
    var ul = document.getElementById('tw-list');
    ul.innerHTML = '';
    topics.forEach(function (t, i) {
      var row = document.createElement('div');
      row.style.cssText = 'display:flex; align-items:center; gap:0.4rem; margin-bottom:0.35rem;';

      var dot = document.createElement('span');
      dot.style.cssText = 'width:11px; height:11px; border-radius:50%; flex-shrink:0; background:'
                        + COLORS[i % COLORS.length] + ';';

      var inp = document.createElement('input');
      inp.type = 'text';
      inp.value = t;
      inp.className = 'tool-input';
      inp.style.cssText = 'flex:1; padding:0.28rem 0.5rem; font-size:0.875rem;';
      inp.dataset.i = i;
      inp.addEventListener('input', function () {
        topics[+this.dataset.i] = this.value;
        redraw();
      });

      var del = document.createElement('button');
      del.innerHTML = '<i class="bi bi-x"></i>';
      del.title = 'Remove topic';
      del.style.cssText = 'background:transparent; border:1px solid #555; color:#aaa;'
                        + 'padding:0.2rem 0.45rem; border-radius:0.25rem; cursor:pointer; flex-shrink:0;';
      del.dataset.i = i;
      del.addEventListener('click', function () {
        topics.splice(+this.dataset.i, 1);
        renderList();
        hideResult();
        redraw();
      });

      row.appendChild(dot); row.appendChild(inp); row.appendChild(del);
      ul.appendChild(row);
    });
  }

  /* ── Result helpers ──────────────────────────────────────────── */
  function showResult(label) {
    document.getElementById('tw-result-text').textContent    = label;
    document.getElementById('tw-fs-result-text').textContent = label;
    document.getElementById('tw-result').style.display    = 'block';
    document.getElementById('tw-fs-result').style.display = 'block';
  }
  function hideResult() {
    document.getElementById('tw-result').style.display    = 'none';
    document.getElementById('tw-fs-result').style.display = 'none';
  }
  function setSpinBtns(disabled) {
    document.getElementById('tw-spin-btn').disabled    = disabled;
    document.getElementById('tw-fs-spin-btn').disabled = disabled;
  }

  /* ── Spin ────────────────────────────────────────────────────── */
  window.twSpin = function () {
    if (isSpinning || topics.length === 0) return;
    isSpinning = true;
    winnerIdx  = -1;
    hideResult();
    setSpinBtns(true);

    var n     = topics.length;
    var seg   = (2 * Math.PI) / n;
    winnerIdx = Math.floor(Math.random() * n);

    var jitter     = (Math.random() - 0.5) * seg * 0.55;
    var targetRaw  = (-Math.PI / 2) - winnerIdx * seg - seg / 2 - jitter;
    var targetNorm = ((targetRaw % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
    var curNorm    = ((spinAngle  % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
    var delta      = targetNorm - curNorm;
    if (delta < 0) delta += 2 * Math.PI;
    var totalSpin  = (5 + Math.floor(Math.random() * 4)) * 2 * Math.PI + delta;

    var startAngle = spinAngle;
    var duration   = 3200 + Math.random() * 1200;
    var startTime  = null;

    function ease(t) { return 1 - Math.pow(1 - t, 4); }

    function step(ts) {
      if (!startTime) startTime = ts;
      var t = Math.min((ts - startTime) / duration, 1);
      spinAngle = startAngle + totalSpin * ease(t);
      redraw();
      if (t < 1) {
        animId = requestAnimationFrame(step);
      } else {
        spinAngle  = startAngle + totalSpin;
        isSpinning = false;
        setSpinBtns(false);
        redraw(winnerIdx);
        var label = (topics[winnerIdx] || '').trim() || ('Topic ' + (winnerIdx + 1));
        showResult(label);
      }
    }
    animId = requestAnimationFrame(step);
  };

  window.twKeep = function () { hideResult(); redraw(); };

  window.twRemove = function () {
    if (winnerIdx >= 0 && winnerIdx < topics.length) {
      topics.splice(winnerIdx, 1);
      winnerIdx = -1;
      renderList();
    }
    hideResult();
    redraw();
  };

  window.twAddTopic = function () {
    topics.push('Topic ' + (topics.length + 1));
    renderList();
    redraw();
  };

  window.twReset = function () {
    if (animId) { cancelAnimationFrame(animId); animId = null; }
    topics     = DEFAULTS.slice();
    spinAngle  = 0;
    winnerIdx  = -1;
    isSpinning = false;
    setSpinBtns(false);
    hideResult();
    renderList();
    redraw();
  };

  /* ── Fullscreen ──────────────────────────────────────────────── */
  window.twOpenFs = function () {
    var fsEl = document.getElementById('tw-fs');
    fsEl.style.display = 'flex';
    fsOpen = true;
    /* Size canvas to viewport on open */
    var size = Math.round(Math.min(window.innerWidth * 0.88, window.innerHeight * 0.62, 700));
    size = Math.max(300, size);
    var fc = document.getElementById('tw-fs-canvas');
    fc.width = fc.height = size;
    redraw(winnerIdx >= 0 ? winnerIdx : undefined);
    if (fsEl.requestFullscreen) fsEl.requestFullscreen().catch(function () {});
    else if (fsEl.webkitRequestFullscreen) fsEl.webkitRequestFullscreen();
  };

  window.twExitFs = function () {
    document.getElementById('tw-fs').style.display = 'none';
    fsOpen = false;
    if (document.exitFullscreen) document.exitFullscreen().catch(function () {});
    else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
  };

  document.addEventListener('fullscreenchange', function () {
    if (document.fullscreenElement === document.getElementById('tw-fs')) {
      /* Entered fullscreen — resize canvas to actual screen */
      var size = Math.round(Math.min(window.screen.width * 0.88, window.screen.height * 0.62, 700));
      size = Math.max(300, size);
      var fc = document.getElementById('tw-fs-canvas');
      fc.width = fc.height = size;
      redraw(winnerIdx >= 0 ? winnerIdx : undefined);
    } else if (!document.fullscreenElement && fsOpen) {
      document.getElementById('tw-fs').style.display = 'none';
      fsOpen = false;
    }
  });

  /* init */
  renderList();
  redraw();
}());
</script>
