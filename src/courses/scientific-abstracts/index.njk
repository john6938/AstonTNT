<script>
(function () {
  var stageEls    = document.querySelectorAll('#sa-stages > div');
  var total       = stageEls.length;
  var current     = 0;
  var paused      = false;
  var timer       = null;
  var abstractEl  = document.getElementById('sa-abstract');
  var wrapEl      = document.getElementById('sa-abstract-wrap');
  var demoEl      = document.querySelector('.sra-demo');
  var badgeEl     = document.getElementById('sa-badge');
  var stepEl      = document.getElementById('sa-step');
  var annotEl     = document.getElementById('sa-annotation');
  var dotsEl      = document.getElementById('sa-dots');
  var progressBar = document.getElementById('sa-progress-bar');

  /* Build dots */
  for (var i = 0; i < total; i++) {
    var dot = document.createElement('button');
    dot.className = 'sa-dot';
    dot.setAttribute('aria-label', 'Stage ' + (i + 1));
    dot.setAttribute('data-index', String(i));
    dotsEl.appendChild(dot);
  }

  function restartProgressBar() {
    progressBar.style.animation = 'none';
    progressBar.offsetHeight; /* force reflow */
    progressBar.style.animation = 'sra-progress-anim 2s linear forwards';
  }

  function stopProgressBar() {
    progressBar.style.animation = 'none';
  }

  function scheduleNext() {
    if (timer) { clearTimeout(timer); }
    if (!paused) {
      timer = setTimeout(function () {
        goToStage((current + 1) % total);
      }, 2000);
    }
  }

  function updateCriterionCards(criterion) {
    document.querySelectorAll('.sra-criterion-card').forEach(function (c) {
      c.classList.remove('sra-criterion-active');
    });
    if (criterion) {
      var card = document.querySelector('.sra-criterion-card[data-criterion="' + criterion + '"]');
      if (card) { card.classList.add('sra-criterion-active'); }
    }
  }

  function goToStage(n) {
    current = n;
    var el = stageEls[n];

    wrapEl.style.opacity = '0';

    setTimeout(function () {
      abstractEl.innerHTML = el.innerHTML;
      wrapEl.style.opacity = '1';

      badgeEl.textContent = el.dataset.label;
      badgeEl.className   = 'sa-badge ' + (el.dataset.badgeClass || '');
      stepEl.textContent  = 'Step ' + (n + 1) + ' of ' + total;
      annotEl.textContent = el.dataset.annotation;

      dotsEl.querySelectorAll('.sa-dot').forEach(function (d, i) {
        d.classList.toggle('sa-dot-active', i === n);
      });

      updateCriterionCards(el.dataset.criterion);

      if (paused) {
        stopProgressBar();
      } else {
        restartProgressBar();
        scheduleNext();
      }
    }, 200);
  }

  /* Toggle pause on click of abstract body */
  wrapEl.addEventListener('click', function () {
    paused = !paused;

    if (paused) {
      if (timer) { clearTimeout(timer); timer = null; }
      stopProgressBar();
      wrapEl.classList.add('sra-paused');
      demoEl.classList.add('sra-is-paused');
      wrapEl.title = 'Click to resume';
    } else {
      wrapEl.classList.remove('sra-paused');
      demoEl.classList.remove('sra-is-paused');
      wrapEl.title = 'Click to pause';
      restartProgressBar();
      scheduleNext();
    }
  });

  /* Dot clicks navigate without changing pause state */
  dotsEl.addEventListener('click', function (e) {
    if (e.target.classList.contains('sa-dot')) {
      var n = parseInt(e.target.dataset.index, 10);
      if (timer) { clearTimeout(timer); }
      goToStage(n);
    }
  });

  /* Initialise */
  goToStage(0);
}());
</script>
