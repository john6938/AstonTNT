<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("John Blake - NLP Research") }}</title>
  <meta name="description" content="{{ description | default('Academic research in Natural Language Processing, Data Structures, and Algorithms') }}">

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="{{ '/favicon.ico' | url }}">
  <!-- Custom CSS -->
  <link href="{{ '/assets/css/main.css' | url }}" rel="stylesheet">
  {% if courseUnit %}
  <link href="{{ '/assets/css/course.css' | url }}" rel="stylesheet">
  {% endif %}
</head>
<body>
  {% include "header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  {% if courseUnit %}
  <!-- compromise NLP — loaded globally so all tool scripts can use nlp() without imports -->
  <script src="https://unpkg.com/compromise@14/builds/compromise.js"></script>
  <script src="{{ '/assets/js/course.js' | url }}"></script>
  {% endif %}
  {# Per-unit tool scripts declared in frontmatter as pageScripts array #}
  {% for script in pageScripts %}
  <script src="{{ script | url }}"></script>
  {% endfor %}
  {% block scripts %}{% endblock %}

</body>
</html>
