{# ══ Review ═══════════════════════════════════════════════════ #}

{% call reviewSection() %}
<div class="accordion mb-3" id="unit08-review">

  {% call accordion("rev-08-a", "Summary: Twelve tense-aspect combinations") %}
  <table class="table table-sm table-dark table-bordered" style="font-size:0.875rem;">
    <thead><tr><th>Aspect</th><th>Past</th><th>Present</th><th>Future</th></tr></thead>
    <tbody>
      <tr><td>Simple</td><td>wrote</td><td>writes</td><td>will write</td></tr>
      <tr><td>Perfect</td><td>had written</td><td>has written</td><td>will have written</td></tr>
      <tr><td>Continuous</td><td>was writing</td><td>is writing</td><td>will be writing</td></tr>
      <tr><td>Perfect continuous</td><td>had been writing</td><td>has been writing</td><td>will have been writing</td></tr>
    </tbody>
  </table>
  {% endcall %}

  {% call accordion("rev-08-b", "How does the parser label passive voice?") %}
  <p>
    Passive constructions (e.g., <em>was written</em>, <em>has been approved</em>) are
    labelled with "Passive" as a prefix: e.g., <em>Passive Past</em> or <em>Passive Present Perfect</em>.
    The tool detects <em>been</em> and <em>being</em> as signals of passive voice.
  </p>
  {% endcall %}

</div>
<p class="mt-3 small" style="color:#e0e0e0;">
  <i class="bi bi-arrow-right-circle"></i>
  Proceed to <a href="{{ (courseBaseUrl + '/unit-09') | url }}">Unit 9: Articles</a> when ready.
</p>
{% endcall %}
