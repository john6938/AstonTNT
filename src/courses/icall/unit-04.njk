{# ══ Review ═══════════════════════════════════════════════════ #}

{% call reviewSection() %}
<div class="accordion mb-3" id="unit04-review">

  {% call accordion("rev-04-a", "Summary: Formal conversion types") %}
  <table class="table table-sm table-dark table-bordered" style="font-size:0.875rem;">
    <thead><tr><th>Type</th><th>Examples converted</th></tr></thead>
    <tbody>
      <tr><td>Slang</td><td>wanna → want to, yeah → yes, cool → good</td></tr>
      <tr><td>Contractions</td><td>I'm → I am, I've → I have, ain't → is not</td></tr>
      <tr><td>Modals</td><td>Can → Could, Will → Would (sentence-initial only)</td></tr>
    </tbody>
  </table>
  {% endcall %}

  {% call accordion("rev-04-b", "When is formal language required?") %}
  <p>
    Formal language is expected in academic essays, research papers, cover letters, official
    reports, and professional emails. Informal language may be acceptable in presentations
    aimed at general audiences, but should be avoided in written academic work.
  </p>
  {% endcall %}

</div>
