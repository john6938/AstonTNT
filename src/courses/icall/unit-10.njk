</div>

<div class="tool-label">Transformation Steps</div>
<div id="steps" class="tool-output" style="min-height:3rem;">
  <span style="color:#666; font-style:italic;">Step-by-step changes will appear here…</span>
</div>
{% endcall %}


{# ══ Activity 4 — Quiz ════════════════════════════════════════ #}

{% call activitySection(4, "Check Your Understanding", "patch-question") %}

{% call quizMC("quiz-10-a", "'I can help you.' — What is the correct reported form?", 2,
   "The modal 'can' backshifts to 'could' in reported speech. The pronoun 'I' changes to 'you' when reporting back to the speaker.") %}
  <label class="quiz-option"><input type="radio" name="quiz-10-a" value="0"> You said that you can help me.</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-a" value="1"> You said that you will help me.</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-a" value="2"> You said that you could help me.</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-a" value="3"> You said that you should help me.</label>
{% endcall %}

<div class="mt-4">
{% call quizMC("quiz-10-b", "What happens to 'tomorrow' in reported speech?", 3,
   "'Tomorrow' becomes 'the following day' in reported speech because the time reference shifts — what was 'tomorrow' at the time of speaking is now 'the following day' from the reporting perspective.") %}
  <label class="quiz-option"><input type="radio" name="quiz-10-b" value="0"> It stays as 'tomorrow'</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-b" value="1"> It changes to 'today'</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-b" value="2"> It changes to 'the day before'</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-b" value="3"> It changes to 'the following day'</label>
{% endcall %}
</div>

<div class="mt-4">
{% call quizMC("quiz-10-c", "'She worked hard.' — What is the correct tense backshift in reported speech?", 1,
   "Past simple backshifts to past perfect in reported speech: 'had worked'.") %}
  <label class="quiz-option"><input type="radio" name="quiz-10-c" value="0"> She works hard.</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-c" value="1"> She had worked hard.</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-c" value="2"> She was working hard.</label>
  <label class="quiz-option"><input type="radio" name="quiz-10-c" value="3"> She would work hard.</label>
{% endcall %}
</div>

{% endcall %}


