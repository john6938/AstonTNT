<script>
(function () {

  var SCENARIOS = [
    {
      situation: 'A student looks visibly confused after your explanation — but does not raise their hand.',
      instruction: 'What do you do next?',
      options: [
        {
          letter: 'A',
          text: 'Repeat the explanation more slowly, with additional examples and clearer notes on the board.',
          type: 'T',
          feedback: '<strong>Structured approach.</strong> Re-explaining is a natural instinct and often helps — but without knowing what the student understood, you may be re-teaching the wrong thing. Repetition increases exposure; it does not always increase comprehension.'
        },
        {
          letter: 'B',
          text: 'Ask the student directly: "Which part is unclear? Can you tell me what you understood so far?"',
          type: 'F',
          feedback: '<strong>Facilitative approach.</strong> Targeted questioning is powerful: it activates the student\'s thinking, gives you diagnostic information, and signals that confusion is a normal part of learning. You discover <em>what</em> is unclear, not just <em>that</em> something is unclear.'
        },
        {
          letter: 'C',
          text: 'Pause the class and ask everyone to discuss the concept with a partner for two minutes.',
          type: 'C',
          feedback: '<strong>Constructivist approach.</strong> Peer discussion deepens understanding for both people involved. It also reduces social pressure on the confused student while giving you a chance to circulate and listen to how different learners are making sense of the material.'
        }
      ]
    },
    {
      situation: 'Most of your class scores below 50% on a test. You did not expect this result.',
      instruction: 'What is your first response?',
      options: [
        {
          letter: 'A',
          text: 'Re-teach the content with clearer explanations, better-organised notes, and more worked examples.',
          type: 'T',
          feedback: '<strong>Structured approach.</strong> More and clearer content is the instinctive response — but it may not address the root cause. Poor performance often reflects gaps in practice, task design, or understanding of the criteria, not just content knowledge.'
        },
        {
          letter: 'B',
          text: 'Ask the class which questions they found hardest and what got in the way of their answers.',
          type: 'F',
          feedback: '<strong>Facilitative approach.</strong> Inviting students to diagnose their own difficulty is metacognitive training. It also reveals whether the gap was in teaching, task design, or student preparation — three very different problems requiring very different responses.'
        },
        {
          letter: 'C',
          text: 'Share the model answer and ask students to mark their own work, then write a short reflection on what they would do differently.',
          type: 'C',
          feedback: '<strong>Constructivist approach.</strong> Self-marking against a model answer is one of the most effective activities in assessment research. It makes criteria visible, builds evaluative judgement, and reframes failure as a productive part of the learning process.'
        }
      ]
    },
    {
      situation: 'You are planning a 50-minute session to introduce a complex new concept for the first time.',
      instruction: 'How do you structure it?',
      options: [
        {
          letter: 'A',
          text: 'Prepare a detailed, well-structured explanation with clear examples, diagrams, and a summary slide.',
          type: 'T',
          feedback: '<strong>Structured approach.</strong> Clear exposition is a legitimate and efficient teaching tool — especially for dense material. The risk is that passive reception without prior activation produces shallow encoding. Students often feel they understood in the moment but cannot recall or apply it later.'
        },
        {
          letter: 'B',
          text: 'Open with a question or short task to surface what students already know, then build your explanation from there.',
          type: 'F',
          feedback: '<strong>Facilitative approach.</strong> Activating prior knowledge before teaching is one of the most consistently supported principles in cognitive science. It primes new information to connect with existing mental frameworks — making encoding deeper and retrieval stronger.'
        },
        {
          letter: 'C',
          text: 'Present a challenging problem that requires the new concept to solve, let students attempt it, then guide a structured debrief.',
          type: 'C',
          feedback: '<strong>Constructivist approach.</strong> Problem-first approaches — sometimes called <em>desirable difficulties</em> — can produce deeper understanding and better transfer than direct instruction. The productive struggle is part of the learning, but effective debriefing is essential.'
        }
      ]
    },
    {
      situation: 'You are writing a learning objective for a session on giving written feedback to students. Which version do you choose?',
      instruction: 'Select the objective that best fits good practice.',
      options: [
        {
          letter: 'A',
          text: '"Students will understand how to give effective written feedback."',
          type: 'T',
          feedback: '<strong>Transmissive framing.</strong> "Understand" is one of the most common — and most problematic — verbs in learning objectives. It is unobservable and unmeasurable. This describes what the <em>teacher</em> will cover, not what the <em>student</em> will be able to do or demonstrate.'
        },
        {
          letter: 'B',
          text: '"Students will be able to explain three principles of effective feedback and apply them to a sample case."',
          type: 'F',
          feedback: '<strong>Well-formed objective.</strong> This uses observable Bloom\'s Taxonomy verbs — <em>explain</em> (comprehension) and <em>apply</em> (application). It is specific and assessable, and tells students exactly what they need to demonstrate. This is the kind of objective that drives coherent lesson and assessment design.'
        },
        {
          letter: 'C',
          text: '"Students will design a feedback protocol for their own course and evaluate its likely impact on student learning."',
          type: 'C',
          feedback: '<strong>High-level Bloom\'s objective.</strong> <em>Design</em> and <em>evaluate</em> sit at the top of Bloom\'s Taxonomy. This is ambitious and learner-centred — but it requires students to have sufficient context to design meaningfully. Better suited to the end of a learning sequence than an introduction.'
        }
      ]
    }
  ];

  var scores  = { T: 0, F: 0, C: 0 };
  var cur     = 0;
  var answered = false;

  function updateDots() {
    for (var i = 0; i < 4; i++) {
      var d = document.getElementById('it-d' + i);
      d.className = 'it-dot';
      if (i < cur)  d.classList.add('it-done');
      if (i === cur) d.classList.add('it-cur');
    }
    ['it-fill', 'it-fill2', 'it-fill3'].forEach(function (id, idx) {
      document.getElementById(id).style.width = cur > idx ? '100%' : '0%';
    });
    document.getElementById('it-cur-num').textContent = cur + 1;
  }

  function render() {
    answered = false;
    var s = SCENARIOS[cur];
    updateDots();

    var optsHTML = s.options.map(function (o, i) {
      return '<button class="it-option" id="ito-' + i + '" onclick="itChoose(' + i + ')">'
        + '<span class="it-opt-letter">' + o.letter + '</span>'
        + '<span>' + o.text + '</span>'
        + '</button>';
    }).join('');

    var nextLabel = cur < 3
      ? 'Next scenario <i class=\'bi bi-arrow-right ms-1\'></i>'
      : 'See your profile <i class=\'bi bi-person-lines-fill ms-1\'></i>';
    var nextFn = cur < 3 ? 'itNext()' : 'itFinish()';

    document.getElementById('it-task-area').innerHTML =
      '<div class="it-panel">'
      + '<div class="it-scenario">' + s.situation + '</div>'
      + '<p class="it-instruction">' + s.instruction + '</p>'
      + '<div class="it-options">' + optsHTML + '</div>'
      + '<div class="it-feedback" id="it-feedback"></div>'
      + '<div class="it-actions">'
      + '<button class="btn btn-sm" id="it-next-btn" onclick="' + nextFn + '" style="display:none; background:#ff8c00; color:#000; font-weight:600; font-size:0.88rem; padding:0.4rem 1.2rem; margin-left:auto;">' + nextLabel + '</button>'
      + '</div>'
      + '</div>';
  }

  window.itChoose = function (idx) {
    if (answered) return;
    answered = true;
    var s = SCENARIOS[cur];
    var chosen = s.options[idx];
    scores[chosen.type]++;

    s.options.forEach(function (o, i) {
      var el = document.getElementById('ito-' + i);
      el.onclick = null;
      el.classList.add(i === idx ? 'it-chosen' : 'it-dimmed');
    });

    var fb = document.getElementById('it-feedback');
    fb.innerHTML = chosen.feedback;
    fb.style.display = 'block';
    document.getElementById('it-next-btn').style.display = 'inline-block';
  };

  window.itNext = function () {
    cur++;
    render();
    document.getElementById('it-task-area').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  window.itFinish = function () {
    var T = scores.T, F = scores.F, C = scores.C;
    var PROFILES = {
      T: {
        name: 'Structured Expert',
        desc: 'You lead with clarity, structure, and well-prepared content. Your students always know where they stand and your explanations are dependable. The course will help you integrate dialogue, targeted questioning, and active learning techniques alongside your existing strengths.'
      },
      F: {
        name: 'Responsive Guide',
        desc: 'You listen carefully, adjust to what you observe, and use questioning to probe and extend understanding. Your instincts are well-calibrated. The course will give you frameworks — for lesson planning, objectives, and alignment — to make those instincts more systematic and transferable.'
      },
      C: {
        name: 'Active Learning Designer',
        desc: 'You design for engagement, discovery, and student agency. You see learning as something students do, not something teachers deliver. The course will help you sharpen your objectives and constructive alignment so your activities are as rigorous as they are engaging.'
      },
      mixed: {
        name: 'Eclectic Practitioner',
        desc: 'You vary your approach depending on context and purpose — a hallmark of reflective, experienced teaching. Rather than defaulting to a single mode, you read the situation. The course will give you frameworks to make those choices even more deliberate and evidence-informed.'
      }
    };

    var max = Math.max(T, F, C);
    var leaders = ['T','F','C'].filter(function (k) { return scores[k] === max; });
    var profile = leaders.length === 1 ? PROFILES[leaders[0]] : PROFILES.mixed;

    var TYPE_LABELS = { T: 'Structured', F: 'Facilitative', C: 'Constructivist' };
    var TYPE_COLORS = {
      T: { bg: 'rgba(74,144,217,0.12)',  color: '#4a90d9', border: 'rgba(74,144,217,0.35)' },
      F: { bg: 'rgba(255,140,0,0.12)',   color: '#ff8c00', border: 'rgba(255,140,0,0.35)'  },
      C: { bg: 'rgba(46,204,113,0.12)',  color: '#2ecc71', border: 'rgba(46,204,113,0.35)' }
    };

    var chipsHTML = ['T','F','C'].map(function (k) {
      var col = TYPE_COLORS[k];
      return '<span class="it-tally-chip" style="background:' + col.bg + '; color:' + col.color + '; border-color:' + col.border + ';">'
        + TYPE_LABELS[k] + ': ' + scores[k] + '</span>';
    }).join('');

    document.getElementById('it-d3').className = 'it-dot it-done';
    document.getElementById('it-fill3').style.width = '100%';
    document.getElementById('it-task-area').style.display = 'none';

    var comp = document.getElementById('it-complete');
    comp.innerHTML =
      '<h3>Your Teaching Profile</h3>'
      + '<div class="it-profile-name">' + profile.name + '</div>'
      + '<div class="it-tally-row">' + chipsHTML + '</div>'
      + '<p class="it-profile-desc">' + profile.desc + '</p>'
      + '<div style="color:#888; font-size:0.82rem; max-width:460px; margin:0 auto 1.5rem;">'
      + '<strong style="color:#ff8c00;">Remember:</strong> No single approach is best. Effective teachers move deliberately between structured, facilitative, and constructivist modes depending on the learning goal, the context, and the learner — which is exactly what this course explores.'
      + '</div>'
      + '<button class="tool-btn" onclick="itRestart()"><i class="bi bi-arrow-repeat me-1"></i> Try again</button>';
    comp.style.display = 'block';
    comp.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  window.itRestart = function () {
    scores = { T: 0, F: 0, C: 0 };
    cur = 0;
    document.getElementById('it-complete').style.display  = 'none';
    document.getElementById('it-task-area').style.display = 'block';
    render();
  };

  render();
}());
</script>
