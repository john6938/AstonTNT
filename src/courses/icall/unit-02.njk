  Enter a simple sentence, then click a modal function to see the sentence rewritten
  in the past, present, and future using the appropriate modal verb.
</p>
<p class="mb-3" style="font-size:0.875rem; color:#aaa;">
  <i class="bi bi-info-circle"></i>
  <strong>Try:</strong> <em>"She sings beautifully."</em> &nbsp;or&nbsp;
  <em>"He reads quickly."</em>
</p>

<div class="mb-2">
  <label class="tool-label" for="textInput">Your sentence</label>
  <input type="text" id="textInput" class="tool-input"
         placeholder="Enter a simple sentence…" aria-label="Sentence input">
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
  <button class="tool-btn" onclick="modifySentence('possibility')">
    <i class="bi bi-question-circle"></i> Possibility
  </button>
  <button class="tool-btn" onclick="modifySentence('ability')">
    <i class="bi bi-lightning"></i> Ability
  </button>
  <button class="tool-btn" onclick="modifySentence('obligation')">
    <i class="bi bi-exclamation-circle"></i> Obligation
  </button>
  <button class="tool-btn" onclick="modifySentence('permission')">
    <i class="bi bi-check-circle"></i> Permission
  </button>
</div>

<div id="loading" style="display:none; color:#aaa; font-size:0.875rem; margin-bottom:0.5rem;">
  <i class="bi bi-hourglass-split"></i> Processing…
</div>

<div class="tool-label">Result</div>
<div id="output" class="tool-output" style="min-height:4rem;">
  <span style="color:#666; font-style:italic;">Select a function above to see the transformation…</span>
</div>
{% endcall %}


{# ══ Activity 4 — Quiz ════════════════════════════════════════ #}

{% call activitySection(4, "Check Your Understanding", "patch-question") %}

{% call quizMC("quiz-02-a", "Which modal verb expresses present ABILITY?", 1,
   "'Can' expresses present ability. 'Could' is used for past ability or polite requests. 'Must' expresses obligation.") %}
  <label class="quiz-option"><input type="radio" name="quiz-02-a" value="0"> Must</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-a" value="1"> Can</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-a" value="2"> Could</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-a" value="3"> Would</label>
{% endcall %}

<div class="mt-4">
{% call quizMC("quiz-02-b", "'You must submit the report by Friday.' This sentence expresses…", 2,
   "'Must' here expresses strong obligation — something that is required or necessary.") %}
  <label class="quiz-option"><input type="radio" name="quiz-02-b" value="0"> Possibility</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-b" value="1"> Permission</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-b" value="2"> Obligation</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-b" value="3"> Ability</label>
{% endcall %}
</div>

<div class="mt-4">
{% call quizMC("quiz-02-c", "Which sentence asks for permission most politely?", 3,
   "'May I' is the most formal and polite way to ask for permission in English.") %}
  <label class="quiz-option"><input type="radio" name="quiz-02-c" value="0"> Can I leave?</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-c" value="1"> Will I leave?</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-c" value="2"> Could I leave?</label>
  <label class="quiz-option"><input type="radio" name="quiz-02-c" value="3"> May I leave?</label>
{% endcall %}
</div>

{% endcall %}


