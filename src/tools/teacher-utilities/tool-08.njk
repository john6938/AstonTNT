<script>
(function () {

  // ── Data ──────────────────────────────────────────────────────────────────
  var VOICE_COLORS = {
    white: '#ffffff', chalk: '#f0ede0', cream: '#f0ede0',
    yellow: '#ffd700', gold: '#ffd700',
    orange: '#ff8c00', amber: '#ff8c00',
    red: '#ff4444', scarlet: '#ff4444',
    green: '#55ee88', lime: '#55ee88',
    blue: '#44ccff', cyan: '#44ccff', aqua: '#44ccff',
    pink: '#ff88cc', magenta: '#ff88cc',
    purple: '#cc66ff', violet: '#cc66ff',
    black: '#111111', dark: '#111111',
    grey: '#aaaaaa', gray: '#aaaaaa', silver: '#aaaaaa'
  };

  var THEMES = {
    green: { bg: '#1c3d1c', border: '#2a5a2a', barBg: 'rgba(0,0,0,0.38)',
             barBorder: 'rgba(255,255,255,0.09)', light: false, defaultFont: '#f0ede0' },
    black: { bg: '#111111', border: '#333333', barBg: 'rgba(0,0,0,0.5)',
             barBorder: 'rgba(255,255,255,0.09)', light: false, defaultFont: '#ffffff' },
    white: { bg: '#f5f5f0', border: '#cccccc', barBg: '#dddddd',
             barBorder: '#bbbbbb',              light: true,  defaultFont: '#111111' }
  };

  // ── State ────────────────────────────────────────────────────────────────
  var fontSize   = 2;
  var fsFontSize = 3.5;
  var theme      = 'black';
  var fontColor  = '#ffffff';
  var listening  = false;
  var fsOpen     = false;
  var lang       = 'en-GB';
  var recognition = null;
  var toastTimer  = null;

  // ── DOM refs ──────────────────────────────────────────────────────────────
  var board     = document.getElementById('wb-board');
  var fsBoard   = document.getElementById('wb-fs-board');
  var mainWrap  = document.getElementById('wb-main');
  var fsMain    = document.getElementById('wb-fs-main');
  var fsOverlay = document.getElementById('wb-fs');

  // ── Helpers: insert coloured span into a contenteditable board ────────────
  // Appends a new <span style="color:…"> to the board at the end.
  function appendText(el, text, color) {
    var span = document.createElement('span');
    span.style.color = color;
    span.textContent = text;
    el.appendChild(span);
    el.scrollTop = el.scrollHeight;
  }

  // After changing colour, prime the cursor in the active board so the next
  // keystroke arrives in the new colour (uses execCommand as the standard
  // rich-text mechanism for contenteditable).
  function primeTypingColor(color) {
    var active = fsOpen ? fsBoard : board;
    // Ensure cursor is in the board
    active.focus();
    // Move selection to end if nothing is selected
    var sel = window.getSelection();
    if (!sel.rangeCount || !active.contains(sel.anchorNode)) {
      var range = document.createRange();
      range.selectNodeContents(active);
      range.collapse(false);
      sel.removeAllRanges();
      sel.addRange(range);
    }
    document.execCommand('foreColor', false, color);
  }

  // ── Speech recognition ────────────────────────────────────────────────────
  var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) {
    document.getElementById('wb-mic').disabled    = true;
    document.getElementById('wb-fs-mic').disabled = true;
    document.getElementById('wb-no-speech').style.display = 'inline';
  } else {
    recognition = new SR();
    recognition.continuous     = true;
    recognition.interimResults = true;
    recognition.lang           = lang;

    recognition.onresult = function (e) {
      var interim = '';
      for (var i = e.resultIndex; i < e.results.length; i++) {
        if (e.results[i].isFinal) {
          var raw   = e.results[i][0].transcript;
          var color = parseColorCommand(raw);
          if (color) {
            wbSetColor(color);
            showToast('Font \u2192 ' + raw.trim().replace(/^.*\bto\s+/i, ''));
          } else {
            // Append coloured span to both boards simultaneously
            appendText(board,   raw + ' ', fontColor);
            appendText(fsBoard, raw + ' ', fontColor);
          }
        } else {
          interim += e.results[i][0].transcript;
        }
      }
      setInterim(interim);
    };

    recognition.onend = function () {
      if (listening) {
        try { recognition.start(); } catch (ex) {}
      } else {
        setInterim('');
      }
    };

    recognition.onerror = function (e) {
      if (e.error === 'no-speech') return;
      setStatus(e.error === 'not-allowed' ? 'Mic blocked' : 'Error: ' + e.error);
      listening = false;
      updateMicUI();
    };
  }

  // ── Voice colour command parser ───────────────────────────────────────────
  // Only matches: "change colour/color to <name>"
  //           or: "change the colour/color to <name>"
  function parseColorCommand(text) {
    var t = text.trim().toLowerCase().replace(/[.,!?]+$/, '');
    var m = t.match(/^change\s+(?:the\s+)?colou?r\s+to\s+(\w+)$/);
    if (m && VOICE_COLORS[m[1]]) return VOICE_COLORS[m[1]];
    return null;
  }

  // ── UI helpers ────────────────────────────────────────────────────────────
  function setInterim(txt) {
    var show = !!txt;
    document.getElementById('wb-interim').style.display    = show ? 'block' : 'none';
    document.getElementById('wb-fs-interim').style.display = show ? 'block' : 'none';
    document.getElementById('wb-interim-text').textContent    = txt;
    document.getElementById('wb-fs-interim-text').textContent = txt;
  }

  function setStatus(msg) {
    document.getElementById('wb-status').textContent    = msg;
    document.getElementById('wb-fs-status').textContent = msg;
  }

  function updateMicUI() {
    var label = listening
      ? '<i class="bi bi-mic-fill"></i> Stop'
      : '<i class="bi bi-mic"></i> Listen';
    ['wb-mic', 'wb-fs-mic'].forEach(function (id) {
      var btn = document.getElementById(id);
      btn.innerHTML = label;
      btn.classList.toggle('wb-on', listening);
    });
    setStatus(listening ? 'Listening\u2026' : '');
    if (!listening) setInterim('');
  }

  function isLightColor(hex) {
    var r = parseInt(hex.slice(1,3), 16);
    var g = parseInt(hex.slice(3,5), 16);
    var b = parseInt(hex.slice(5,7), 16);
    return (r * 0.299 + g * 0.587 + b * 0.114) > 150;
  }

  function applyTheme(name) {
    var t = THEMES[name];
    // Auto-adjust font colour when switching to avoid invisible text
    if (t.light && isLightColor(fontColor)) {
      fontColor = '#111111';
    } else if (!t.light && !isLightColor(fontColor)) {
      fontColor = '#f0ede0';
    }
    [mainWrap, fsMain].forEach(function (el) {
      el.style.background  = t.bg;
      el.style.borderColor = t.border;
      if (t.light) el.classList.add('wb-lt');
      else         el.classList.remove('wb-lt');
    });
    fsOverlay.style.background = t.bg;
    [document.getElementById('wb-bar'), document.getElementById('wb-fs-bar')].forEach(function (el) {
      el.style.background   = t.barBg;
      el.style.borderColor  = t.barBorder;
    });
    document.querySelectorAll('.wb-theme-opt').forEach(function (btn) {
      btn.classList.toggle('wb-act', btn.getAttribute('data-theme') === name);
    });
    applyColorUI();
  }

  function applyColorUI() {
    // Update preview dot
    document.getElementById('wb-color-dot').style.background    = fontColor;
    document.getElementById('wb-fs-color-dot').style.background = fontColor;
    // Update colour pickers
    document.getElementById('wb-cpick').value    = fontColor;
    document.getElementById('wb-fs-cpick').value = fontColor;
    // Update active swatch ring
    document.querySelectorAll('.wb-swatch').forEach(function (sw) {
      sw.classList.toggle('wb-act', sw.getAttribute('data-color') === fontColor);
    });
  }

  function showToast(msg) {
    ['wb-toast', 'wb-fs-toast'].forEach(function (id) {
      var el = document.getElementById(id);
      el.textContent   = msg;
      el.style.display = 'block';
    });
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function () {
      ['wb-toast', 'wb-fs-toast'].forEach(function (id) {
        document.getElementById(id).style.display = 'none';
      });
    }, 1800);
  }

  function syncLang(val) {
    document.getElementById('wb-lang').value    = val;
    document.getElementById('wb-fs-lang').value = val;
  }

  // ── Public API ────────────────────────────────────────────────────────────
  window.wbToggleMic = function () {
    if (!SR) return;
    listening = !listening;
    if (listening) { recognition.lang = lang; recognition.start(); }
    else           { recognition.stop(); }
    updateMicUI();
  };

  window.wbSetLang = function (val) {
    lang = val;
    syncLang(val);
    if (recognition) recognition.lang = val;
    if (listening) recognition.stop();
  };

  window.wbFontUp = function () {
    fontSize   = Math.min(fontSize   + 0.4, 7);
    fsFontSize = Math.min(fsFontSize + 0.6, 10);
    board.style.fontSize   = fontSize   + 'rem';
    fsBoard.style.fontSize = fsFontSize + 'rem';
  };

  window.wbFontDown = function () {
    fontSize   = Math.max(fontSize   - 0.4, 0.8);
    fsFontSize = Math.max(fsFontSize - 0.6, 1.2);
    board.style.fontSize   = fontSize   + 'rem';
    fsBoard.style.fontSize = fsFontSize + 'rem';
  };

  window.wbSetTheme = function (name) {
    theme = name;
    applyTheme(name);
    primeTypingColor(fontColor);
  };

  window.wbSetColor = function (hex) {
    fontColor = hex;
    applyColorUI();
    primeTypingColor(hex);
  };

  window.wbClear = function () {
    if ((board.innerHTML.trim() || fsBoard.innerHTML.trim()) && !confirm('Clear the board?')) return;
    board.innerHTML   = '';
    fsBoard.innerHTML = '';
    (fsOpen ? fsBoard : board).focus();
    primeTypingColor(fontColor);
  };

  window.wbOpenFs = function () {
    fsBoard.innerHTML = board.innerHTML;
    fsOverlay.style.display = 'flex';
    fsOpen = true;
    if (fsOverlay.requestFullscreen)
      fsOverlay.requestFullscreen().catch(function () {});
    else if (fsOverlay.webkitRequestFullscreen)
      fsOverlay.webkitRequestFullscreen();
    setTimeout(function () {
      fsBoard.focus();
      fsBoard.scrollTop = fsBoard.scrollHeight;
      primeTypingColor(fontColor);
    }, 80);
  };

  window.wbCloseFs = function () {
    board.innerHTML = fsBoard.innerHTML;
    fsOverlay.style.display = 'none';
    fsOpen = false;
    if (document.exitFullscreen)
      document.exitFullscreen().catch(function () {});
    else if (document.webkitExitFullscreen)
      document.webkitExitFullscreen();
    board.focus();
    primeTypingColor(fontColor);
  };

  document.addEventListener('fullscreenchange', function () {
    if (!document.fullscreenElement && fsOpen) {
      board.innerHTML = fsBoard.innerHTML;
      fsOverlay.style.display = 'none';
      fsOpen = false;
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && fsOpen) window.wbCloseFs();
  });

  // ── Boot ──────────────────────────────────────────────────────────────────
  board.style.fontSize   = fontSize   + 'rem';
  fsBoard.style.fontSize = fsFontSize + 'rem';
  applyTheme('black');
  board.focus();
  primeTypingColor(fontColor);

})();
</script>
