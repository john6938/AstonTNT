  var RESP = {
    r2: {
      equal: '<strong>50:50 balance:</strong> Reasonable, but a higher proportion of formative activity across the 12 weeks provides more learning opportunities and reduces high-stakes pressure.',
      formative: '<strong>More formative (70:30):</strong> Excellent. Regular low-stakes formative checkpoints throughout the course scaffold learning and reduce anxiety, leading to better summative performance.',
      summative: '<strong>More summative (30:70):</strong> Creates a high-stakes environment with insufficient feedback opportunities. Students may struggle without enough formative support to guide their learning.'
    },
