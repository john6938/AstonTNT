---
tool: 3
toolTitle: Attention Getter
title: "Tool 3: Attention Getter — Teacher Utilities"
description: "A visual and audio signal to quickly bring the class back to attention."
---

<div class="course-tool-section mb-4">

  <div class="activity-header">
    <span class="activity-num"><i class="bi bi-bell"></i></span>
    <h2 class="activity-title-text">Attention Getter</h2>
  </div>

  <p style="color:#ccc; margin-bottom:1.25rem;">
    Press Signal to flash a full-screen prompt and play the chosen sound. Click the overlay (or press Escape) to dismiss.
  </p>

  {# ── Message ── #}
  <div class="mb-3">
    <label class="tool-label">Message to display</label>
    <input type="text" id="attn-message" class="tool-input"
           style="font-size:1.1rem; font-weight:600;" value="Stop and listen!">
  </div>

  {# ── Sound selector ── #}
  <div class="mb-4">
    <label class="tool-label">Sound</label>
    <select id="attn-sound" class="form-select"
            style="background:#333; color:#fff; border-color:#555; max-width:360px;">
      <option value="chime">Chime — gentle descending tone (2 s)</option>
      <option value="bell">School bell — short burst (0.5 s)</option>
      <option value="three-beeps">Three beeps (1.5 s)</option>
      <option value="long-tone">Long sustained tone (4 s)</option>
      <option value="fanfare">Ascending fanfare — three notes (2 s)</option>
      <option value="two-tone">Two-tone signal (1 s)</option>
      <option value="alarm">Alarm — oscillating (3 s)</option>
      <option value="none">No sound</option>
    </select>
  </div>

  {# ── Signal button — always visible ── #}
  <button class="tool-btn" style="font-size:1.2rem; padding:0.75rem 2.5rem;"
          onclick="attentionSignal()">
    <i class="bi bi-megaphone-fill"></i>&nbsp; Signal!
  </button>

</div>

{# ── Full-screen overlay ── #}
<div id="attn-overlay" style="display:none; position:fixed; inset:0; background:#ff8c00;
     z-index:9999; flex-direction:column; align-items:center; justify-content:center;
     cursor:pointer;" onclick="attentionDismiss()">
  <p id="attn-overlay-msg"
     style="font-size:min(10vw,5.5rem); font-weight:900; color:#000;
            text-align:center; padding:1rem; margin:0; line-height:1.1; flex:1;
            display:flex; align-items:center; justify-content:center;"></p>
  <p style="color:#000; font-size:1.1rem; opacity:0.55; margin:0 0 1.5rem;">
    Click anywhere or press Escape to dismiss
  </p>
</div>

<script>
(function() {

  function playSound(type) {
    if (type === 'none') return;
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();

      function tone(freq, startT, dur, type, gainPeak) {
        var osc  = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type = type || 'sine';
        osc.frequency.setValueAtTime(freq, startT);
        gain.gain.setValueAtTime(gainPeak || 0.4, startT);
        gain.gain.exponentialRampToValueAtTime(0.001, startT + dur);
        osc.start(startT);
        osc.stop(startT + dur);
      }

      var t = ctx.currentTime;

      if (type === 'chime') {
        var osc  = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(880, t);
        osc.frequency.exponentialRampToValueAtTime(440, t + 1.8);
        gain.gain.setValueAtTime(0.5, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 2.0);
        osc.start(t); osc.stop(t + 2.0);

      } else if (type === 'bell') {
        tone(660, t, 0.5, 'square', 0.3);

      } else if (type === 'three-beeps') {
        tone(880, t + 0.0, 0.3, 'sine', 0.4);
        tone(880, t + 0.5, 0.3, 'sine', 0.4);
        tone(880, t + 1.0, 0.5, 'sine', 0.4);

      } else if (type === 'long-tone') {
        var osc  = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(528, t);
        gain.gain.setValueAtTime(0.0, t);
        gain.gain.linearRampToValueAtTime(0.45, t + 0.3);
        gain.gain.setValueAtTime(0.45, t + 3.4);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 4.0);
        osc.start(t); osc.stop(t + 4.0);

      } else if (type === 'fanfare') {
        tone(523, t + 0.0, 0.35, 'sine', 0.45);   // C5
        tone(659, t + 0.4, 0.35, 'sine', 0.45);   // E5
        tone(784, t + 0.8, 0.8,  'sine', 0.45);   // G5

      } else if (type === 'two-tone') {
        tone(660, t + 0.0, 0.4, 'sine', 0.4);
        tone(440, t + 0.5, 0.5, 'sine', 0.4);

      } else if (type === 'alarm') {
        var osc  = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'square';
        osc.frequency.setValueAtTime(880, t);
        for (var i = 0; i < 6; i++) {
          osc.frequency.setValueAtTime(880, t + i * 0.5);
          osc.frequency.setValueAtTime(440, t + i * 0.5 + 0.25);
        }
        gain.gain.setValueAtTime(0.25, t);
        gain.gain.setValueAtTime(0.25, t + 2.8);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 3.0);
        osc.start(t); osc.stop(t + 3.0);
      }
    } catch(e) {}
  }

  window.attentionSignal = function() {
    var msg   = document.getElementById('attn-message').value || 'Stop and listen!';
    var sound = document.getElementById('attn-sound').value;
    document.getElementById('attn-overlay-msg').textContent = msg;
    document.getElementById('attn-overlay').style.display = 'flex';
    playSound(sound);
  };

  window.attentionDismiss = function() {
    document.getElementById('attn-overlay').style.display = 'none';
  };

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') window.attentionDismiss();
  });
})();
</script>
