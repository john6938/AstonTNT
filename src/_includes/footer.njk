<footer class="bg-dark text-light py-4 mt-5">
  <div class="container">
    {% if quote %}
    <p class="text-end fst-italic mb-3" style="color: #ffffff;">{{ quote | safe }}</p>
    {% endif %}
    <p class="text-end mb-3" style="color: #ffffff;">
      <a href="{{ '/' | url }}" style="color: #ffffff; text-decoration: none;">Home</a>
      {% for item in navigation.main %}
      | <a href="{{ item.url | url }}" style="color: #ffffff; text-decoration: none;">{{ item.text }}</a>
      {% endfor %}
    </p>
    <div class="d-flex flex-column flex-md-row justify-content-md-end gap-1 gap-md-3 text-end" style="color: #ffffff;">
      <span>John Blake</span>
      <span>Aston University</span>
      <span>&copy; {% year %} All rights reserved</span>
    </div>
  </div>
</footer>
