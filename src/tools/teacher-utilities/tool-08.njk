      </div>

      <span class="wb-sep"></span>

      <span class="wb-color-preview" id="wb-color-dot"></span>
      <div class="wb-palette">
        <button class="wb-swatch" data-color="#f0ede0" style="background:#f0ede0;" onclick="wbSetColor('#f0ede0')" title="Chalk"></button>
        <button class="wb-swatch wb-act" data-color="#ffffff" style="background:#ffffff;" onclick="wbSetColor('#ffffff')" title="White"></button>
        <button class="wb-swatch" data-color="#ffd700" style="background:#ffd700;" onclick="wbSetColor('#ffd700')" title="Yellow"></button>
        <button class="wb-swatch" data-color="#ff8c00" style="background:#ff8c00;" onclick="wbSetColor('#ff8c00')" title="Orange"></button>
        <button class="wb-swatch" data-color="#ff4444" style="background:#ff4444;" onclick="wbSetColor('#ff4444')" title="Red"></button>
        <button class="wb-swatch" data-color="#55ee88" style="background:#55ee88;" onclick="wbSetColor('#55ee88')" title="Green"></button>
        <button class="wb-swatch" data-color="#44ccff" style="background:#44ccff;" onclick="wbSetColor('#44ccff')" title="Blue"></button>
        <button class="wb-swatch" data-color="#ff88cc" style="background:#ff88cc;" onclick="wbSetColor('#ff88cc')" title="Pink"></button>
        <button class="wb-swatch" data-color="#111111" style="background:#111111;" onclick="wbSetColor('#111111')" title="Black"></button>
        <input class="wb-cpick" type="color" id="wb-cpick" value="#f0ede0"
